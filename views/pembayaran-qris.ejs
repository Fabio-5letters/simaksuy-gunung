<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pembayaran QRIS - SIMAKSI Gunung</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
      * { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
      .gradient-header { background: linear-gradient(135deg, #1e5631 0%, #2d7a3e 50%, #3a9f5d 100%); }
      .btn-pay { background: linear-gradient(135deg, #1e5631 0%, #3a9f5d 100%); transition: all 0.3s ease; }
      .btn-pay:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(30, 86, 49, 0.3); }
      .pulse { animation: pulse 2s infinite; }
      @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.7; }
      }
      .countdown { font-variant-numeric: tabular-nums; }
    </style>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">

    <!-- Navbar -->
    <header class="gradient-header text-white shadow-xl sticky top-0 z-50">
        <div class="container mx-auto flex justify-between items-center py-4 px-6">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center">
                    <i class="fas fa-mountain text-green-700 text-lg"></i>
                </div>
                <h1 class="text-2xl font-bold">SIMAKSI Gunung</h1>
            </div>
            <a href="/pendakian" class="text-white hover:text-green-200 transition">
                <i class="fas fa-arrow-left mr-2"></i>Kembali
            </a>
        </div>
    </header>

    <!-- Progress Steps -->
    <div class="bg-white shadow-sm border-b">
        <div class="container mx-auto px-6 py-4">
            <div class="flex items-center justify-center space-x-4">
                <div class="flex items-center">
                    <div class="w-8 h-8 rounded-full bg-green-600 text-white flex items-center justify-center font-bold text-sm">1</div>
                    <span class="ml-2 text-sm font-medium text-green-600">Formulir</span>
                </div>
                <div class="w-12 h-0.5 bg-green-600"></div>
                <div class="flex items-center">
                    <div class="w-8 h-8 rounded-full bg-green-600 text-white flex items-center justify-center font-bold text-sm">2</div>
                    <span class="ml-2 text-sm font-medium text-green-600">Pembayaran</span>
                </div>
                <div class="w-12 h-0.5 bg-gray-300"></div>
                <div class="flex items-center">
                    <div class="w-8 h-8 rounded-full bg-gray-200 text-gray-500 flex items-center justify-center font-bold text-sm">3</div>
                    <span class="ml-2 text-sm font-medium text-gray-500">Unggah Bukti</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container mx-auto px-6 py-10 max-w-3xl">
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
            <!-- Header -->
            <div class="gradient-header text-white p-6 text-center">
                <div class="w-16 h-16 bg-white bg-opacity-20 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-qrcode text-3xl"></i>
                </div>
                <h2 class="text-2xl font-bold mb-2">Pembayaran QRIS</h2>
                <p class="text-green-100">Scan QR Code di bawah untuk melakukan pembayaran</p>
            </div>

            <div class="p-8">
                <!-- Booking Info Card -->
                <div class="bg-gray-50 rounded-xl p-6 mb-6 border border-gray-200">
                    <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                        <i class="fas fa-receipt text-green-600 mr-2"></i>Detail Pemesanan
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <p class="text-sm text-gray-500">Kode Booking</p>
                            <p class="font-mono font-bold text-lg text-green-700"><%= pemesanan.kode_booking %></p>
                        </div>
                        <div>
                            <p class="text-sm text-gray-500">Nama Pendaki</p>
                            <p class="font-semibold text-gray-900"><%= user.nama %></p>
                        </div>
                        <div>
                            <p class="text-sm text-gray-500">Tujuan</p>
                            <p class="font-semibold text-gray-900"><%= pemesanan.nama_gunung %> (<%= pemesanan.ketinggian %> mdpl)</p>
                        </div>
                        <div>
                            <p class="text-sm text-gray-500">Tanggal Pendakian</p>
                            <p class="font-semibold text-gray-900">
                                <%= new Date(pemesanan.tanggal_masuk).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                                - 
                                <%= new Date(pemesanan.tanggal_keluar).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                            </p>
                        </div>
                        <div>
                            <p class="text-sm text-gray-500">Pintu Masuk / Keluar</p>
                            <p class="font-semibold text-gray-900"><%= pemesanan.pintu_masuk %> → <%= pemesanan.pintu_keluar %></p>
                        </div>
                        <div>
                            <p class="text-sm text-gray-500">Jumlah Anggota</p>
                            <p class="font-semibold text-gray-900"><%= pemesanan.jumlah_anggota %> orang</p>
                        </div>
                    </div>
                </div>

                <!-- QRIS Code Section -->
                <div class="text-center mb-6">
                    <div class="bg-white border-2 border-dashed border-green-300 rounded-xl p-8 inline-block shadow-inner">
                        <!-- Dummy QR Code - Replace with actual QRIS generator -->
                        <div class="bg-white p-4 rounded-lg">
                            <img src="https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=<%= pemesanan.kode_booking %>&color=1e5631" 
                                 alt="QR Code Pembayaran" 
                                 class="w-64 h-64 mx-auto">
                        </div>
                        <p class="text-sm text-gray-500 mt-4">
                            <i class="fas fa-info-circle mr-1"></i>
                            Scan QR Code menggunakan aplikasi e-wallet atau mobile banking
                        </p>
                    </div>
                </div>

                <!-- Total Payment -->
                <div class="bg-gradient-to-r from-green-50 to-emerald-50 rounded-xl p-6 mb-6 border border-green-200">
                    <div class="flex justify-between items-center">
                        <div>
                            <p class="text-sm text-green-700 font-medium">Total Pembayaran</p>
                            <p class="text-xs text-green-600 mt-1">
                                <%= pemesanan.jumlah_anggota %> orang × <%= formatRupiah(pemesanan.harga_per_orang) %>
                            </p>
                        </div>
                        <p class="text-3xl font-black text-green-700"><%= formatRupiah(pemesanan.total_bayar) %></p>
                    </div>
                </div>

                <!-- Payment Method -->
                <div class="flex items-center justify-center space-x-3 mb-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
                    <i class="fas fa-credit-card text-blue-600"></i>
                    <span class="text-sm font-medium text-blue-800">Metode: QRIS</span>
                    <span class="text-xs text-blue-600">(<%= pemesanan.metode_pembayaran %>)</span>
                </div>

                <!-- Timer / Info -->
                <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-6 text-center">
                    <p class="text-sm text-yellow-800">
                        <i class="fas fa-clock mr-2 pulse"></i>
                        Selesaikan pembayaran dalam <span class="font-bold countdown" id="countdown">15:00</span> menit
                    </p>
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-col sm:flex-row gap-4">
                    <form action="/konfirmasi-bayar/<%= pemesanan.kode_booking %>" method="POST" class="flex-1">
                        <button type="submit" class="w-full btn-pay text-white font-bold py-4 px-6 rounded-xl flex items-center justify-center text-lg">
                            <i class="fas fa-check-circle mr-2"></i>
                            Saya Sudah Bayar
                        </button>
                    </form>
                    <a href="/pendakian" class="flex-1 bg-gray-200 text-gray-700 font-bold py-4 px-6 rounded-xl flex items-center justify-center text-lg hover:bg-gray-300 transition">
                        <i class="fas fa-times-circle mr-2"></i>
                        Batal
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="gradient-header text-white py-8 mt-12">
        <div class="container mx-auto px-6 text-center text-green-100 text-sm">
            <p>&copy; 2026 SIMAKSI - Sistem Informasi Manajemen Pendakian Gunung</p>
        </div>
    </footer>

    <!-- Countdown Timer Script -->
    <script>
        // 15 minute countdown
        let timeLeft = 15 * 60; // 15 minutes in seconds
        const countdownEl = document.getElementById('countdown');

        const timer = setInterval(() => {
            const minutes = Math.floor(timeLeft / 60);
            const seconds = timeLeft % 60;
            countdownEl.textContent = `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
            timeLeft--;

            if (timeLeft < 0) {
                clearInterval(timer);
                window.location.href = '/pendakian';
            }
        }, 1000);
    </script>
</body>
</html>
