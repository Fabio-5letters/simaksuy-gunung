<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Status Pendakian - SIMAKSI Gunung</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .card-hover {
            transition: all 0.3s ease;
        }
        .card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }
        .hero-section {
            background: linear-gradient(135deg, #1a3c34 0%, #2d5a4c 100%);
        }
        .status-card {
            background: white;
            border-radius: 1rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            overflow: hidden;
            border: 1px solid #e5e7eb;
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">
    <!-- Header -->
    <header class="bg-white shadow-md sticky top-0 z-40">
        <div class="container mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-4">
                    <div class="w-10 h-10 bg-green-700 rounded-lg flex items-center justify-center text-white">
                        <i class="fas fa-mountain text-xl"></i>
                    </div>
                    <div>
                        <h1 class="text-xl font-bold text-green-800 leading-tight">SIMAKSI</h1>
                        <p class="text-xs text-gray-500 uppercase tracking-wider">Gunung Indonesia</p>
                    </div>
                </div>
                <nav class="hidden md:flex space-x-6">
                    <a href="/beranda" class="text-gray-600 hover:text-green-700 font-medium transition">Beranda</a>
                    <a href="/berita" class="text-gray-600 hover:text-green-700 font-medium transition">Berita</a>
                    <a href="/pendakian" class="text-gray-600 hover:text-green-700 font-medium transition">Pendakian</a>
                    <a href="/status" class="text-green-700 font-bold border-b-2 border-green-700">Status</a>
                    <a href="/kontak" class="text-gray-600 hover:text-green-700 font-medium transition">Kontak</a>
                </nav>
                <div class="flex items-center">
                    <% if (user) { %>
                        <div class="flex items-center space-x-3 bg-gray-100 px-3 py-1.5 rounded-full">
                            <span class="text-sm font-semibold text-gray-700"><%= user.nama %></span>
                            <div class="w-8 h-8 bg-green-600 rounded-full flex items-center justify-center text-white text-xs">
                                <%= user.nama.charAt(0) %>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero-section text-white py-12 px-6">
        <div class="container mx-auto text-center">
            <h2 class="text-3xl md:text-4xl font-extrabold mb-2">Monitor Status Anda</h2>
            <p class="text-green-100 opacity-90">Pantau perkembangan pengajuan izin pendakian Anda secara real-time</p>
        </div>
    </section>

    <!-- Main Content -->
    <main class="flex-grow container mx-auto px-6 py-12">
        <div class="max-w-5xl mx-auto">
            <div class="flex items-center justify-between mb-8">
                <h3 class="text-2xl font-bold text-gray-800 flex items-center">
                    <i class="fas fa-clipboard-list mr-3 text-green-600"></i>
                    Daftar Pengajuan SIMAKSI
                </h3>
                <div class="text-sm text-gray-500">
                    Total: <%= simaksi ? simaksi.length : 0 %> Pengajuan
                </div>
            </div>

            <% if (simaksi && simaksi.length > 0) { %>
                <div class="space-y-6">
                    <% simaksi.forEach(item => { %>
                        <div class="status-card flex flex-col md:flex-row">
                            <!-- Left: Mountain Info -->
                            <div class="bg-gray-50 p-6 md:w-1/3 border-b md:border-b-0 md:border-r border-gray-100">
                                <div class="flex items-center mb-4">
                                    <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center text-green-700 mr-4">
                                        <i class="fas fa-mountain-sun text-2xl"></i>
                                    </div>
                                    <div>
                                        <h4 class="font-bold text-gray-900 leading-tight"><%= item.nama_gunung %></h4>
                                        <p class="text-xs text-gray-500"><%= item.lokasi %></p>
                                    </div>
                                </div>
                                <div class="space-y-2 text-sm">
                                    <div class="flex justify-between text-gray-600">
                                        <span>ID Pengajuan</span>
                                        <span class="font-mono font-bold text-gray-900">#<%= item.id %></span>
                                    </div>
                                    <div class="flex justify-between text-gray-600">
                                        <span>Tanggal Ajuan</span>
                                        <span class="font-medium"><%= item.created_at ? new Date(item.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) : '-' %></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Middle: Details -->
                            <div class="p-6 flex-grow flex flex-col justify-center">
                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <p class="text-xs text-gray-400 uppercase font-bold tracking-wider mb-1">Tanggal Pendakian</p>
                                        <p class="text-gray-900 font-semibold">
                                            <i class="far fa-calendar-check mr-2 text-blue-500"></i>
                                            <%= new Date(item.tanggal_pendakian).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %>
                                        </p>
                                    </div>
                                    <div>
                                        <p class="text-xs text-gray-400 uppercase font-bold tracking-wider mb-1">Jumlah Anggota</p>
                                        <p class="text-gray-900 font-semibold">
                                            <i class="fas fa-users mr-2 text-purple-500"></i>
                                            <%= item.jumlah_anggota %> Orang
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <!-- Right: Status & Action -->
                            <div class="p-6 bg-white md:w-1/4 flex flex-col items-center justify-center border-t md:border-t-0 border-gray-100">
                                <div class="mb-3">
                                    <% if (item.status_pengajuan === 'Pending') { %>
                                        <span class="px-4 py-2 bg-yellow-100 text-yellow-700 rounded-full text-xs font-bold uppercase tracking-widest flex items-center">
                                            <i class="fas fa-spinner fa-spin mr-2"></i> Pending
                                        </span>
                                    <% } else if (item.status_pengajuan === 'Disetujui') { %>
                                        <span class="px-4 py-2 bg-green-100 text-green-700 rounded-full text-xs font-bold uppercase tracking-widest flex items-center">
                                            <i class="fas fa-check-circle mr-2"></i> Disetujui
                                        </span>
                                    <% } else if (item.status_pengajuan === 'Ditolak') { %>
                                        <span class="px-4 py-2 bg-red-100 text-red-700 rounded-full text-xs font-bold uppercase tracking-widest flex items-center">
                                            <i class="fas fa-times-circle mr-2"></i> Ditolak
                                        </span>
                                    <% } else { %>
                                        <span class="px-4 py-2 bg-gray-100 text-gray-700 rounded-full text-xs font-bold uppercase tracking-widest">
                                            <%= item.status_pengajuan || 'Unknown' %>
                                        </span>
                                    <% } %>
                                </div>
                                <p class="text-[10px] text-gray-400 text-center uppercase tracking-tighter">Status Terakhir</p>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="bg-white rounded-2xl shadow-sm p-12 text-center border border-dashed border-gray-300">
                    <div class="w-20 h-20 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-300">
                        <i class="fas fa-folder-open text-4xl"></i>
                    </div>
                    <h4 class="text-xl font-bold text-gray-900 mb-2">Belum Ada Pengajuan</h4>
                    <p class="text-gray-500 mb-8 max-w-sm mx-auto">Anda belum memiliki riwayat pengajuan izin pendakian. Silakan pilih gunung dan ajukan SIMAKSI Anda.</p>
                    <a href="/pendakian" class="inline-flex items-center px-6 py-3 bg-green-700 text-white font-bold rounded-xl hover:bg-green-800 transition shadow-lg shadow-green-200">
                        <i class="fas fa-plus-circle mr-2"></i> Ajukan SIMAKSI Sekarang
                    </a>
                </div>
            <% } %>

            <!-- Legend Info -->
            <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="bg-yellow-50 p-4 rounded-xl border border-yellow-100 flex items-start">
                    <i class="fas fa-info-circle text-yellow-500 mt-1 mr-3"></i>
                    <div>
                        <p class="text-xs font-bold text-yellow-800 uppercase mb-1">Menunggu Review</p>
                        <p class="text-[11px] text-yellow-700 leading-tight">Admin sedang memverifikasi data dan kuota pendakian Anda.</p>
                    </div>
                </div>
                <div class="bg-green-50 p-4 rounded-xl border border-green-100 flex items-start">
                    <i class="fas fa-check-circle text-green-500 mt-1 mr-3"></i>
                    <div>
                        <p class="text-xs font-bold text-green-800 uppercase mb-1">Disetujui</p>
                        <p class="text-[11px] text-green-700 leading-tight">Izin diterbitkan. Anda dapat mencetak tiket di menu Riwayat.</p>
                    </div>
                </div>
                <div class="bg-red-50 p-4 rounded-xl border border-red-100 flex items-start">
                    <i class="fas fa-exclamation-triangle text-red-500 mt-1 mr-3"></i>
                    <div>
                        <p class="text-xs font-bold text-red-800 uppercase mb-1">Ditolak</p>
                        <p class="text-[11px] text-red-700 leading-tight">Pengajuan tidak sesuai atau kuota penuh. Silakan ajukan ulang.</p>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer class="bg-gray-900 text-white py-8 mt-12">
        <div class="container mx-auto px-6 text-center">
            <p class="text-gray-500 text-sm">© 2024 SIMAKSI Gunung Indonesia. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>