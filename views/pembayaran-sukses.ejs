<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pembayaran Berhasil - SIMAKSI Gunung</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
      * { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
      .gradient-header { background: linear-gradient(135deg, #1e5631 0%, #2d7a3e 50%, #3a9f5d 100%); }
      .btn-primary { background: linear-gradient(135deg, #1e5631 0%, #3a9f5d 100%); transition: all 0.3s ease; }
      .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(30, 86, 49, 0.3); }
      .success-icon { animation: scaleIn 0.6s ease-out, bounce 0.6s ease-out 0.6s; }
      @keyframes scaleIn {
        0% { transform: scale(0); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
      }
      @keyframes bounce {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
      }
      .confetti { animation: confettiFall 3s ease-out forwards; }
      @keyframes confettiFall {
        0% { transform: translateY(-100vh) rotate(0deg); opacity: 1; }
        100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
      }
    </style>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">

    <!-- Confetti effect -->
    <div id="confetti-container" class="fixed inset-0 pointer-events-none z-50 overflow-hidden">
        <% for (let i = 0; i < 30; i++) { %>
            <div class="confetti absolute w-3 h-3 rounded-full" 
                 style="
                    left: <%= Math.random() * 100 %>%;
                    background: <%= ['#1e5631', '#3a9f5d', '#4CAF50', '#81C784', '#FFD700', '#FF6B6B'][Math.floor(Math.random() * 6)] %>;
                    animation-delay: <%= Math.random() * 2 %>s;
                    animation-duration: <%= 2 + Math.random() * 2 %>s;
                 ">
            </div>
        <% } %>
    </div>

    <!-- Navbar -->
    <header class="gradient-header text-white shadow-xl sticky top-0 z-40">
        <div class="container mx-auto flex justify-between items-center py-4 px-6">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center">
                    <i class="fas fa-mountain text-green-700 text-lg"></i>
                </div>
                <h1 class="text-2xl font-bold">SIMAKSI Gunung</h1>
            </div>
            <a href="/beranda" class="text-white hover:text-green-200 transition">
                <i class="fas fa-home mr-1"></i>Beranda
            </a>
        </div>
    </header>

    <!-- Main Content -->
    <div class="container mx-auto px-6 py-16 max-w-2xl">
        <div class="bg-white rounded-2xl shadow-2xl overflow-hidden text-center">
            <!-- Success Header -->
            <div class="gradient-header text-white p-10">
                <div class="success-icon w-24 h-24 bg-white rounded-full flex items-center justify-center mx-auto mb-6 shadow-lg">
                    <i class="fas fa-check text-green-600 text-5xl"></i>
                </div>
                <h2 class="text-3xl font-black mb-2">Berhasil!</h2>
                <p class="text-green-100 text-lg">Bukti pembayaran Anda telah berhasil diunggah</p>
            </div>

            <div class="p-8">
                <!-- Order Details -->
                <div class="bg-gray-50 rounded-xl p-6 mb-6 border border-gray-200 text-left">
                    <h3 class="text-sm font-bold text-gray-900 mb-4 uppercase tracking-wide flex items-center">
                        <i class="fas fa-receipt text-green-600 mr-2"></i>Detail Pemesanan
                    </h3>
                    <div class="space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="text-gray-500 text-sm">Kode Booking</span>
                            <span class="font-mono font-bold text-green-700"><%= pemesanan.kode_booking %></span>
                        </div>
                        <div class="border-t border-gray-200"></div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-500 text-sm">Tujuan</span>
                            <span class="font-semibold"><%= pemesanan.nama_gunung %></span>
                        </div>
                        <div class="border-t border-gray-200"></div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-500 text-sm">Tanggal</span>
                            <span class="font-semibold">
                                <%= new Date(pemesanan.tanggal_masuk).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                - 
                                <%= new Date(pemesanan.tanggal_keluar).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                            </span>
                        </div>
                        <div class="border-t border-gray-200"></div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-500 text-sm">Jumlah Anggota</span>
                            <span class="font-semibold"><%= pemesanan.jumlah_anggota %> orang</span>
                        </div>
                        <div class="border-t border-gray-200"></div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-500 text-sm">Total Dibayar</span>
                            <span class="font-bold text-xl text-green-700"><%= formatRupiah(pemesanan.total_bayar) %></span>
                        </div>
                    </div>
                </div>

                <!-- Status Card -->
                <div class="bg-yellow-50 border-2 border-yellow-300 rounded-xl p-5 mb-6">
                    <div class="flex items-center justify-center mb-3">
                        <div class="w-12 h-12 bg-yellow-200 rounded-full flex items-center justify-center">
                            <i class="fas fa-hourglass-half text-yellow-700 text-xl"></i>
                        </div>
                    </div>
                    <h4 class="font-bold text-yellow-800 text-lg mb-2">Menunggu Verifikasi Admin</h4>
                    <p class="text-sm text-yellow-700">
                        Bukti pembayaran Anda sedang diverifikasi oleh tim kami. 
                        Proses verifikasi memakan waktu maksimal <strong>1x24 jam</strong>.
                    </p>
                </div>

                <!-- What's Next -->
                <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 mb-6 text-left">
                    <h4 class="font-bold text-blue-800 mb-3 flex items-center">
                        <i class="fas fa-lightbulb text-blue-600 mr-2"></i>Langkah Selanjutnya
                    </h4>
                    <ul class="space-y-2 text-sm text-blue-700">
                        <li class="flex items-start">
                            <span class="w-6 h-6 bg-blue-200 rounded-full flex items-center justify-center text-xs font-bold mr-3 flex-shrink-0">1</span>
                            <span>Admin akan memverifikasi bukti pembayaran Anda</span>
                        </li>
                        <li class="flex items-start">
                            <span class="w-6 h-6 bg-blue-200 rounded-full flex items-center justify-center text-xs font-bold mr-3 flex-shrink-0">2</span>
                            <span>Status akan diperbarui di halaman <strong>STATUS PEMESANAN</strong></span>
                        </li>
                        <li class="flex items-start">
                            <span class="w-6 h-6 bg-blue-200 rounded-full flex items-center justify-center text-xs font-bold mr-3 flex-shrink-0">3</span>
                            <span>Jika disetujui, Anda akan mendapat konfirmasi via email</span>
                        </li>
                        <li class="flex items-start">
                            <span class="w-6 h-6 bg-blue-200 rounded-full flex items-center justify-center text-xs font-bold mr-3 flex-shrink-0">4</span>
                            <span>Siapkan dokumen dan perlengkapan untuk hari pendakian!</span>
                        </li>
                    </ul>
                </div>

                <!-- Action Buttons -->
                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="/status-pemesanan/<%= pemesanan.kode_booking %>" class="flex-1 btn-primary text-white font-bold py-4 px-6 rounded-xl flex items-center justify-center text-lg">
                        <i class="fas fa-eye mr-2"></i>
                        Lihat Status Pesanan
                    </a>
                    <a href="/beranda" class="flex-1 bg-gray-200 text-gray-700 font-bold py-4 px-6 rounded-xl flex items-center justify-center text-lg hover:bg-gray-300 transition">
                        <i class="fas fa-home mr-2"></i>
                        Ke Beranda
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="gradient-header text-white py-8 mt-12">
        <div class="container mx-auto px-6 text-center text-green-100 text-sm">
            <p>&copy; 2026 SIMAKSI - Sistem Informasi Manajemen Pendakian Gunung</p>
        </div>
    </footer>

    <!-- Auto-hide confetti after 4 seconds -->
    <script>
        setTimeout(() => {
            const confettiContainer = document.getElementById('confetti-container');
            if (confettiContainer) {
                confettiContainer.style.display = 'none';
            }
        }, 4000);
    </script>
</body>
</html>
