<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Informasi Cuaca - SIMAKSI Gunung</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .card-hover {
            transition: all 0.3s ease;
        }
        .card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }
        .hero-section {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        .weather-card {
            background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 100%);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.2);
        }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Header -->
    <header class="bg-white shadow-lg sticky top-0 z-40">
        <div class="container mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-4">
                    <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=50&h=50&fit=crop&crop=center" alt="Logo" class="w-12 h-12 rounded-full">
                    <div>
                        <h1 class="text-2xl font-bold text-green-700">SIMAKSI</h1>
                        <p class="text-sm text-gray-600">Gunung</p>
                    </div>
                </div>
                <nav class="hidden md:flex space-x-8">
                    <a href="/beranda" class="text-gray-700 hover:text-green-600 font-semibold transition">Beranda</a>
                    <a href="/berita" class="text-gray-700 hover:text-green-600 font-semibold transition">Berita</a>
                    <a href="/pendakian" class="text-gray-700 hover:text-green-600 font-semibold transition">Pendakian</a>
                    <a href="/cuaca" class="text-green-600 font-semibold">Cuaca</a>
                    <a href="/status" class="text-gray-700 hover:text-green-600 font-semibold transition">Status</a>
                    <a href="/panduan" class="text-gray-700 hover:text-green-600 font-semibold transition">Panduan</a>
                    <a href="/kontak" class="text-gray-700 hover:text-green-600 font-semibold transition">Kontak</a>
                </nav>
                <div class="flex items-center space-x-4">
                    <% if (user) { %>
                        <div class="relative">
                            <button onclick="toggleDropdown()" class="flex items-center space-x-2 bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition">
                                <i class="fas fa-user-circle"></i>
                                <span class="hidden md:block"><%= user.nama %></span>
                                <i class="fas fa-chevron-down text-sm"></i>
                            </button>
                            <div id="profile-dropdown" class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-200 hidden z-50">
                                <div class="py-2">
                                    <div class="px-4 py-2 border-b border-gray-100">
                                        <p class="text-sm font-medium text-gray-900"><%= user.nama %></p>
                                        <p class="text-xs text-gray-500"><%= user.email %></p>
                                    </div>
                                    <a href="/profile" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition">
                                        <i class="fas fa-user-circle mr-2"></i>Profile Saya
                                    </a>
                                    <a href="/riwayat" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition">
                                        <i class="fas fa-history mr-2"></i>Riwayat Pendakian
                                    </a>
                                    <div class="border-t border-gray-100"></div>
                                    <a href="/logout" class="block px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition">
                                        <i class="fas fa-sign-out-alt mr-2"></i>Logout
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% } else { %>
                        <a href="/login" class="bg-green-600 text-white px-6 py-2 rounded-lg font-semibold hover:bg-green-700 transition">Login</a>
                    <% } %>
                </div>
            </div>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="hero-section min-h-64 flex items-center justify-center text-white py-16 px-6">
        <div class="text-center max-w-2xl">
            <h2 class="text-4xl md:text-5xl font-black mb-4 drop-shadow-lg">
                <i class="fas fa-cloud-sun mr-3"></i>Informasi Cuaca
            </h2>
            <p class="text-xl md:text-xl drop-shadow-md">Pantau kondisi cuaca terkini di setiap gunung untuk perencanaan pendakian yang aman</p>
        </div>
    </section>

    <!-- Weather Information Section -->
    <section class="py-20 bg-white">
        <div class="container mx-auto px-6">
            <div class="text-center mb-12">
                <h3 class="text-3xl font-bold text-gray-900 mb-4">Kondisi Cuaca Gunung</h3>
                <p class="text-gray-600 text-lg">Informasi cuaca terkini dan prakiraan untuk membantu perencanaan pendakian Anda</p>
            </div>

            <!-- Current Weather Summary -->
            <div class="bg-gradient-to-r from-blue-600 to-purple-600 rounded-2xl p-8 text-white mb-12">
                <div class="text-center mb-6">
                    <h4 class="text-2xl font-bold mb-2">Ringkasan Cuaca Hari Ini</h4>
                    <p class="text-blue-100">Update terakhir: <%= new Date().toLocaleString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
                </div>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    <div class="text-center">
                        <i class="fas fa-temperature-high text-3xl text-yellow-300 mb-2"></i>
                        <p class="text-sm text-blue-100">Suhu Rata-rata</p>
                        <p class="text-2xl font-bold">18-25°C</p>
                    </div>
                    <div class="text-center">
                        <i class="fas fa-tint text-3xl text-blue-300 mb-2"></i>
                        <p class="text-sm text-blue-100">Kelembaban</p>
                        <p class="text-2xl font-bold">65-85%</p>
                    </div>
                    <div class="text-center">
                        <i class="fas fa-wind text-3xl text-green-300 mb-2"></i>
                        <p class="text-sm text-blue-100">Kecepatan Angin</p>
                        <p class="text-2xl font-bold">5-15 km/h</p>
                    </div>
                    <div class="text-center">
                        <i class="fas fa-cloud text-3xl text-gray-300 mb-2"></i>
                        <p class="text-sm text-blue-100">Kondisi Umum</p>
                        <p class="text-2xl font-bold">Berawan</p>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
                <% gunung.forEach((item, index) => { %>
                    <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                        <!-- Mountain Header -->
                        <div class="bg-gradient-to-r from-green-600 to-green-700 text-white p-6">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h4 class="text-xl font-bold"><%= item.nama_gunung %></h4>
                                    <p class="text-green-100 text-sm"><i class="fas fa-map-marker-alt mr-1"></i><%= item.lokasi %></p>
                                </div>
                                <div class="text-right">
                                    <div class="text-3xl font-bold">
                                        <% const temps = [22, 18, 25, 20, 23, 19, 24, 21];
                                           const temp = temps[index % temps.length]; %>
                                        <%= temp %>°C
                                    </div>
                                    <div class="text-sm text-green-100">Suhu saat ini</div>
                                </div>
                            </div>
                        </div>

                        <!-- Weather Details -->
                        <div class="p-6">
                            <div class="grid grid-cols-2 gap-4 mb-6">
                                <!-- Temperature Details -->
                                <div class="bg-blue-50 rounded-lg p-4">
                                    <div class="flex items-center mb-2">
                                        <i class="fas fa-thermometer-half text-blue-600 mr-2"></i>
                                        <span class="font-semibold text-gray-900">Suhu</span>
                                    </div>
                                    <div class="space-y-1 text-sm">
                                        <div class="flex justify-between">
                                            <span class="text-gray-600">Minimum:</span>
                                            <span class="font-semibold"><%= temp - 5 %>°C</span>
                                        </div>
                                        <div class="flex justify-between">
                                            <span class="text-gray-600">Maksimum:</span>
                                            <span class="font-semibold"><%= temp + 8 %>°C</span>
                                        </div>
                                        <div class="flex justify-between">
                                            <span class="text-gray-600">Terasa seperti:</span>
                                            <span class="font-semibold"><%= temp - 2 %>°C</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Wind & Humidity -->
                                <div class="bg-green-50 rounded-lg p-4">
                                    <div class="flex items-center mb-2">
                                        <i class="fas fa-wind text-green-600 mr-2"></i>
                                        <span class="font-semibold text-gray-900">Angin & Kelembaban</span>
                                    </div>
                                    <div class="space-y-1 text-sm">
                                        <div class="flex justify-between">
                                            <span class="text-gray-600">Kecepatan:</span>
                                            <span class="font-semibold">
                                                <% const winds = [8, 12, 6, 15, 10, 7, 9, 11];
                                                   const wind = winds[index % winds.length]; %>
                                                <%= wind %> km/h
                                            </span>
                                        </div>
                                        <div class="flex justify-between">
                                            <span class="text-gray-600">Arah:</span>
                                            <span class="font-semibold">
                                                <% const directions = ['Barat Laut', 'Timur', 'Selatan', 'Barat Daya', 'Utara', 'Timur Laut', 'Selatan', 'Barat'];
                                                   const direction = directions[index % directions.length]; %>
                                                <%= direction %>
                                            </span>
                                        </div>
                                        <div class="flex justify-between">
                                            <span class="text-gray-600">Kelembaban:</span>
                                            <span class="font-semibold">
                                                <% const humidities = [75, 68, 82, 71, 79, 73, 77, 69];
                                                   const humidity = humidities[index % humidities.length]; %>
                                                <%= humidity %>%
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Weather Condition & Status -->
                            <div class="bg-gray-50 rounded-lg p-4 mb-6">
                                <div class="flex items-center justify-between mb-3">
                                    <div class="flex items-center">
                                        <i class="fas fa-cloud text-2xl text-gray-600 mr-3"></i>
                                        <div>
                                            <p class="font-semibold text-gray-900">Kondisi Cuaca</p>
                                            <p class="text-sm text-gray-600">
                                                <% const conditions = ['Cerah Berawan', 'Berawan Tebal', 'Hujan Ringan', 'Cerah', 'Mendung', 'Hujan Sedang', 'Berawan', 'Cerah Berawan'];
                                                   const condition = conditions[index % conditions.length]; %>
                                                <%= condition %>
                                            </p>
                                        </div>
                                    </div>
                                    <div class="text-right">
                                        <div class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium
                                            <% const statuses = ['bg-green-500', 'bg-yellow-500', 'bg-orange-500', 'bg-green-500', 'bg-blue-500', 'bg-red-500', 'bg-green-500', 'bg-green-500'];
                                               const status = statuses[index % statuses.length]; %>
                                            <%= status %> text-white">
                                            <i class="fas fa-circle mr-1 text-xs"></i>
                                            <% if (status.includes('green')) { %>
                                                Aman Pendakian
                                            <% } else if (status.includes('yellow')) { %>
                                                Waspada
                                            <% } else if (status.includes('orange')) { %>
                                                Siaga
                                            <% } else if (status.includes('red')) { %>
                                                Bahaya
                                            <% } else { %>
                                                Normal
                                            <% } %>
                                        </div>
                                    </div>
                                </div>

                                <!-- Additional Weather Info -->
                                <div class="grid grid-cols-3 gap-4 text-center">
                                    <div>
                                        <i class="fas fa-sun text-yellow-500 text-lg mb-1"></i>
                                        <p class="text-xs text-gray-600">UV Index</p>
                                        <p class="font-semibold">
                                            <% const uvs = ['Sedang', 'Tinggi', 'Rendah', 'Sedang', 'Tinggi', 'Rendah', 'Sedang', 'Tinggi'];
                                               const uv = uvs[index % uvs.length]; %>
                                            <%= uv %>
                                        </p>
                                    </div>
                                    <div>
                                        <i class="fas fa-eye text-blue-500 text-lg mb-1"></i>
                                        <p class="text-xs text-gray-600">Visibilitas</p>
                                        <p class="font-semibold">
                                            <% const visibilities = ['10 km', '8 km', '12 km', '9 km', '11 km', '7 km', '13 km', '6 km'];
                                               const visibility = visibilities[index % visibilities.length]; %>
                                            <%= visibility %>
                                        </p>
                                    </div>
                                    <div>
                                        <i class="fas fa-tachometer-alt text-purple-500 text-lg mb-1"></i>
                                        <p class="text-xs text-gray-600">Tekanan</p>
                                        <p class="font-semibold">
                                            <% const pressures = ['1013 hPa', '1015 hPa', '1012 hPa', '1014 hPa', '1011 hPa', '1016 hPa', '1010 hPa', '1017 hPa'];
                                               const pressure = pressures[index % pressures.length]; %>
                                            <%= pressure %>
                                        </p>
                                    </div>
                                </div>
                            </div>

                            <!-- Sunrise & Sunset -->
                            <div class="bg-orange-50 rounded-lg p-4">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center">
                                        <i class="fas fa-sun text-orange-500 mr-2"></i>
                                        <span class="font-semibold text-gray-900">Matahari Terbit</span>
                                    </div>
                                    <span class="font-semibold">
                                        <% const sunrises = ['05:45', '05:42', '05:48', '05:43', '05:47', '05:41', '05:49', '05:44'];
                                           const sunrise = sunrises[index % sunrises.length]; %>
                                        <%= sunrise %> WIB
                                    </span>
                                </div>
                                <div class="flex items-center justify-between mt-2">
                                    <div class="flex items-center">
                                        <i class="fas fa-moon text-indigo-500 mr-2"></i>
                                        <span class="font-semibold text-gray-900">Matahari Terbenam</span>
                                    </div>
                                    <span class="font-semibold">
                                        <% const sunsets = ['17:52', '17:55', '17:50', '17:54', '17:51', '17:56', '17:49', '17:53'];
                                           const sunset = sunsets[index % sunsets.length]; %>
                                        <%= sunset %> WIB
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>

            <!-- 7-Day Forecast -->
            <div class="bg-white rounded-xl shadow-lg p-8 mb-12">
                <h4 class="text-2xl font-bold text-gray-900 mb-6 text-center">
                    <i class="fas fa-calendar-alt text-blue-600 mr-2"></i>Prakiraan Cuaca 7 Hari
                </h4>
                <div class="overflow-x-auto">
                    <div class="min-w-full">
                        <div class="grid grid-cols-7 gap-4">
                            <% const days = ['Hari Ini', 'Besok', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat'];
                               const forecastTemps = [
                                   { min: 18, max: 26 }, { min: 19, max: 27 }, { min: 17, max: 25 },
                                   { min: 20, max: 28 }, { min: 18, max: 26 }, { min: 21, max: 29 }, { min: 19, max: 27 }
                               ];
                               const forecastConditions = ['Cerah', 'Berawan', 'Hujan', 'Cerah', 'Berawan', 'Cerah', 'Hujan'];

                               days.forEach((day, index) => { %>
                                <div class="text-center p-4 bg-gray-50 rounded-lg">
                                    <p class="font-semibold text-gray-900 mb-2"><%= day %></p>
                                    <i class="fas fa-<%= forecastConditions[index] === 'Cerah' ? 'sun' : forecastConditions[index] === 'Berawan' ? 'cloud' : 'cloud-rain' %> text-2xl text-blue-600 mb-2"></i>
                                    <p class="text-sm text-gray-600 mb-1"><%= forecastConditions[index] %></p>
                                    <p class="font-bold text-lg"><%= forecastTemps[index].max %>°</p>
                                    <p class="text-sm text-gray-500"><%= forecastTemps[index].min %>°</p>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Weather Tips -->
            <div class="mt-16 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-2xl p-8">
                <h4 class="text-2xl font-bold text-center text-gray-900 mb-6">
                    <i class="fas fa-lightbulb text-yellow-500 mr-2"></i>Tips Cuaca untuk Pendakian
                </h4>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div class="bg-white rounded-lg p-6 shadow-sm">
                        <div class="flex items-start">
                            <i class="fas fa-sun text-yellow-500 text-2xl mr-4 mt-1"></i>
                            <div>
                                <h5 class="font-semibold text-gray-900 mb-2">Cuaca Cerah</h5>
                                <p class="text-gray-600 text-sm">Kondisi ideal untuk pendakian. Pastikan tetap terhidrasi dan gunakan sunscreen.</p>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white rounded-lg p-6 shadow-sm">
                        <div class="flex items-start">
                            <i class="fas fa-cloud-rain text-blue-500 text-2xl mr-4 mt-1"></i>
                            <div>
                                <h5 class="font-semibold text-gray-900 mb-2">Cuaca Hujan</h5>
                                <p class="text-gray-600 text-sm">Tunda pendakian jika memungkinkan. Gunakan jaket anti air dan peralatan keselamatan.</p>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white rounded-lg p-6 shadow-sm">
                        <div class="flex items-start">
                            <i class="fas fa-wind text-green-500 text-2xl mr-4 mt-1"></i>
                            <div>
                                <h5 class="font-semibold text-gray-900 mb-2">Angin Kencang</h5>
                                <p class="text-gray-600 text-sm">Berhati-hati dengan angin kencang. Gunakan pakaian hangat dan jaga keseimbangan.</p>
                            </div>
                        </div>
                    </div>
                    <div class="bg-white rounded-lg p-6 shadow-sm">
                        <div class="flex items-start">
                            <i class="fas fa-thermometer-half text-red-500 text-2xl mr-4 mt-1"></i>
                            <div>
                                <h5 class="font-semibold text-gray-900 mb-2">Suhu Dingin</h5>
                                <p class="text-gray-600 text-sm">Gunakan layering pakaian dan pastikan fisik dalam kondisi prima.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Weather Warnings -->
            <div class="mt-12 bg-gradient-to-r from-red-50 to-orange-50 rounded-2xl p-8 border-l-4 border-red-500">
                <div class="flex items-start">
                    <i class="fas fa-exclamation-triangle text-red-500 text-3xl mr-4 mt-1"></i>
                    <div>
                        <h4 class="text-xl font-bold text-gray-900 mb-3">Peringatan Cuaca</h4>
                        <div class="space-y-2 text-gray-700">
                            <p><strong>⚠️ Potensi Hujan:</strong> Beberapa gunung berpotensi mengalami hujan pada sore hingga malam hari.</p>
                            <p><strong>🌡️ Suhu Dingin:</strong> Pada ketinggian di atas 2000 mdpl, suhu dapat mencapai 10°C pada malam hari.</p>
                            <p><strong>💨 Angin Kencang:</strong> Waspada angin kencang di puncak gunung pada pagi dan sore hari.</p>
                            <p><strong>🔅 UV Tinggi:</strong> Indeks UV sedang hingga tinggi, gunakan sunscreen dan pelindung matahari.</p>
                        </div>
                        <div class="mt-4">
                            <button class="bg-red-600 text-white px-6 py-2 rounded-lg font-semibold hover:bg-red-700 transition">
                                <i class="fas fa-info-circle mr-2"></i>Lihat Detail Peringatan
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-12">
        <div class="container mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div>
                    <h3 class="text-xl font-bold mb-4">SIMAKSI Gunung</h3>
                    <p class="text-gray-400">Sistem Informasi Manajemen Pendakian Gunung untuk pengalaman mendaki yang aman dan terorganisir.</p>
                </div>
                <div>
                    <h4 class="text-lg font-semibold mb-4">Menu Utama</h4>
                    <ul class="space-y-2">
                        <li><a href="/beranda" class="text-gray-400 hover:text-white transition">Beranda</a></li>
                        <li><a href="/berita" class="text-gray-400 hover:text-white transition">Berita</a></li>
                        <li><a href="/pendakian" class="text-gray-400 hover:text-white transition">Pendakian</a></li>
                        <li><a href="/cuaca" class="text-gray-400 hover:text-white transition">Cuaca</a></li>
                        <li><a href="/status" class="text-gray-400 hover:text-white transition">Status</a></li>
                        <li><a href="/panduan" class="text-gray-400 hover:text-white transition">Panduan</a></li>
                        <li><a href="/kontak" class="text-gray-400 hover:text-white transition">Kontak</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-lg font-semibold mb-4">Layanan</h4>
                    <ul class="space-y-2">
                        <li><a href="/riwayat" class="text-gray-400 hover:text-white transition">Riwayat Pendakian</a></li>
                        <li><a href="/status" class="text-gray-400 hover:text-white transition">Status Pendakian</a></li>
                        <li><a href="/panduan" class="text-gray-400 hover:text-white transition">Panduan</a></li>
                        <li><a href="/kontak" class="text-gray-400 hover:text-white transition">Kontak</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-lg font-semibold mb-4">Kontak</h4>
                    <div class="space-y-2 text-gray-400">
                        <p><i class="fas fa-phone mr-2"></i>+62 123 4567 890</p>
                        <p><i class="fas fa-envelope mr-2"></i>info@simaksigunung.id</p>
                        <p><i class="fas fa-map-marker-alt mr-2"></i>Jawa Tengah, Indonesia</p>
                    </div>
                </div>
            </div>
            <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-400">
                <p>&copy; 2024 SIMAKSI Gunung. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script>
        function toggleDropdown() {
            const dropdown = document.getElementById('profile-dropdown');
            dropdown.classList.toggle('hidden');
        }

        // Close dropdown when clicking outside
        document.addEventListener('click', function(event) {
            const dropdown = document.getElementById('profile-dropdown');
            const button = event.target.closest('button');
            if (!button || !button.onclick || !button.onclick.toString().includes('toggleDropdown')) {
                if (!dropdown.contains(event.target)) {
                    dropdown.classList.add('hidden');
                }
            }
        });
    </script>
</body>
</html>
