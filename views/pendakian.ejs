<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pendakian - SIMAKSI Gunung Merbabu</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
      * {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      }
      .navbar-gradient {
        background: linear-gradient(135deg, #1e5631 0%, #2d7a3e 50%, #3a9f5d 100%);
      }
      .card-hover {
        transition: all 0.3s ease;
      }
      .card-hover:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(30, 86, 49, 0.15);
      }
      .btn-primary {
        background: linear-gradient(135deg, #1e5631 0%, #3a9f5d 100%);
        transition: all 0.3s ease;
      }
      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(30, 86, 49, 0.3);
      }
    </style>
</head>
<body class="bg-gray-50">
    <div class="min-h-screen">
        <!-- Navbar -->
        <header class="navbar-gradient text-white shadow-xl sticky top-0 z-50">
            <div class="container mx-auto flex justify-between items-center py-4 px-6">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center">
                        <i class="fas fa-mountain text-green-700 text-lg"></i>
                    </div>
                    <h1 class="text-2xl font-bold">SIMAKSI Gunung</h1>
                </div>
                <nav class="hidden md:block">
                    <ul class="flex space-x-8 font-semibold">
                        <li><a href="/beranda" class="hover:text-green-200 transition duration-300 flex items-center space-x-2"><i class="fas fa-home"></i><span>Beranda</span></a></li>
                        <li><a href="/berita" class="hover:text-green-200 transition duration-300 flex items-center space-x-2"><i class="fas fa-newspaper"></i><span>Berita</span></a></li>
                        <li><a href="/pendakian" class="hover:text-green-200 transition duration-300 flex items-center space-x-2"><i class="fas fa-person-hiking"></i><span>Pendakian</span></a></li>
                        <li><a href="/kontak" class="hover:text-green-200 transition duration-300 flex items-center space-x-2"><i class="fas fa-envelope"></i><span>Kontak</span></a></li>
                    </ul>
                </nav>
                <div class="flex space-x-4">
                    <% if (user) { %>
                        <div class="relative">
                            <button id="profile-btn" class="flex items-center space-x-3 bg-white text-green-700 px-4 py-2 rounded-lg font-semibold hover:bg-green-50 transition">
                                <div class="w-8 h-8 bg-green-600 rounded-full flex items-center justify-center">
                                    <i class="fas fa-user text-white text-sm"></i>
                                </div>
                                <span><%= user.nama %></span>
                                <i class="fas fa-chevron-down text-sm"></i>
                            </button>
                            <div id="profile-dropdown" class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-200 hidden z-50">
                                <div class="py-2">
                                    <div class="px-4 py-2 border-b border-gray-100">
                                        <p class="text-sm font-medium text-gray-900"><%= user.nama %></p>
                                        <p class="text-xs text-gray-500"><%= user.email %></p>
                                    </div>
                                    <a href="/profile" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition">
                                        <i class="fas fa-user-circle mr-2"></i>Profile Saya
                                    </a>
                                    <a href="/riwayat" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition">
                                        <i class="fas fa-history mr-2"></i>Riwayat Pendakian
                                    </a>
                                    <div class="border-t border-gray-100"></div>
                                    <a href="/logout" class="block px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition">
                                        <i class="fas fa-sign-out-alt mr-2"></i>Logout
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% } else { %>
                        <a href="/login" class="bg-white text-green-700 px-6 py-2 rounded-lg font-semibold hover:bg-green-50 transition">Login</a>
                    <% } %>
                </div>
            </div>
        </header>

        <!-- Hero Section -->
        <section class="bg-gradient-to-r from-green-600 to-green-800 text-white py-20 px-6">
            <div class="container mx-auto text-center">
                <h2 class="text-4xl md:text-5xl font-black mb-4">Pilih Tujuan Pendakian</h2>
                <p class="text-xl text-green-100 max-w-2xl mx-auto">Jelajahi berbagai puncak gunung di Pulau Jawa dan mulailah petualangan Anda</p>
            </div>
        </section>

        <!-- Gunung Content -->
        <section class="py-20 bg-white">
            <div class="container mx-auto px-6">
                <% if (gunung && gunung.length > 0) { %>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                        <% gunung.forEach(item => { %>
                            <div class="card-hover group">
                                <div class="relative overflow-hidden rounded-xl shadow-lg">
                                    <div class="h-56 bg-gradient-to-br from-green-400 to-green-600 overflow-hidden">
                                        <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=500&h=400&fit=crop" alt="<%= item.nama_gunung %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                                    </div>
                                    <div class="absolute inset-0 bg-black bg-opacity-30 group-hover:bg-opacity-20 transition pointer-events-none"></div>
                                    <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black to-transparent p-6 text-white z-10">
                                        <div class="flex items-center justify-between">
                                            <div>
                                                <h4 class="text-2xl font-bold"><%= item.nama_gunung %></h4>
                                                <p class="text-sm text-gray-300 flex items-center mt-1"><i class="fas fa-map-marker-alt mr-1"></i><%= item.lokasi %></p>
                                                <p class="text-sm text-gray-300 flex items-center mt-1"><i class="fas fa-arrow-up mr-1"></i><%= item.ketinggian %> mdpl</p>
                                            </div>
                                            <div class="text-right">
                                                <p class="text-sm text-gray-300">Kuota: <%= item.kuota_harian %>/hari</p>
                                                <span class="inline-block px-2 py-1 text-xs rounded-full <%= item.status === 'Buka' ? 'bg-green-500' : 'bg-red-500' %> text-white">
                                                    <%= item.status %>
                                                </span>
                                            </div>
                                        </div>
                                        <% if (user) { %>
                                            <a href="/daftar/<%= item.id %>" class="mt-4 w-full btn-primary text-white font-semibold py-2 rounded-lg transition flex items-center justify-center">
                                                <i class="fas fa-plus-circle mr-2"></i>Daftar Pendakian
                                            </a>
                                        <% } else { %>
                                            <a href="/login" class="mt-4 w-full btn-primary text-white font-semibold py-2 rounded-lg transition flex items-center justify-center">
                                                <i class="fas fa-sign-in-alt mr-2"></i>Login untuk Daftar
                                            </a>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                <% } else { %>
                    <div class="text-center py-20">
                        <i class="fas fa-mountain text-6xl text-gray-300 mb-4"></i>
                        <h3 class="text-2xl font-bold text-gray-600 mb-2">Belum ada gunung tersedia</h3>
                        <p class="text-gray-500">Data gunung akan segera ditambahkan oleh admin.</p>
                    </div>
                <% } %>
            </div>
        </section>

        <!-- Informasi Detail Gunung -->
        <% if (gunung && gunung.length > 0) { %>
        <section class="py-20 bg-gray-50">
            <div class="container mx-auto px-6">
                <div class="text-center mb-12">
                    <h2 class="text-4xl font-black text-gray-900 mb-4">Informasi Gunung</h2>
                    <p class="text-xl text-gray-600 max-w-3xl mx-auto">Pelajari lebih lanjut tentang setiap gunung sebelum memulai pendakian Anda</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <% gunung.forEach(item => { %>
                        <div class="bg-white rounded-2xl shadow-xl overflow-hidden hover:shadow-2xl transition duration-300">
                            <div class="h-48 bg-gradient-to-br from-green-400 to-green-600 relative overflow-hidden">
                                <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=800&h=400&fit=crop" alt="<%= item.nama_gunung %>" class="w-full h-full object-cover opacity-30">
                                <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent"></div>
                                <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
                                    <h3 class="text-3xl font-black mb-2"><%= item.nama_gunung %></h3>
                                    <div class="flex items-center space-x-4 text-sm">
                                        <span class="flex items-center"><i class="fas fa-map-marker-alt mr-1"></i><%= item.lokasi %></span>
                                        <span class="flex items-center"><i class="fas fa-arrow-up mr-1"></i><%= item.ketinggian %> mdpl</span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="p-6">
                                <div class="grid grid-cols-3 gap-4 mb-6">
                                    <div class="text-center bg-green-50 rounded-lg p-3">
                                        <i class="fas fa-users text-green-600 text-2xl mb-2"></i>
                                        <p class="text-xs text-gray-600">Kuota Harian</p>
                                        <p class="text-lg font-bold text-gray-900"><%= item.kuota_harian %></p>
                                    </div>
                                    <div class="text-center bg-blue-50 rounded-lg p-3">
                                        <i class="fas fa-check-circle text-blue-600 text-2xl mb-2"></i>
                                        <p class="text-xs text-gray-600">Status</p>
                                        <p class="text-sm font-bold <%= item.status === 'Buka' ? 'text-green-600' : 'text-red-600' %>"><%= item.status %></p>
                                    </div>
                                    <div class="text-center bg-purple-50 rounded-lg p-3">
                                        <i class="fas fa-mountain text-purple-600 text-2xl mb-2"></i>
                                        <p class="text-xs text-gray-600">Ketinggian</p>
                                        <p class="text-lg font-bold text-gray-900"><%= item.ketinggian %>m</p>
                                    </div>
                                </div>

                                <% if (item.deskripsi) { %>
                                    <div class="prose prose-sm max-w-none">
                                        <h4 class="text-lg font-bold text-gray-900 mb-3 flex items-center">
                                            <i class="fas fa-info-circle text-green-600 mr-2"></i>Tentang Gunung
                                        </h4>
                                        <p class="text-gray-700 text-sm leading-relaxed line-clamp-4"><%= item.deskripsi %></p>
                                        <a href="/pendakian/<%= item.id %>" class="inline-flex items-center mt-4 text-green-600 hover:text-green-700 font-semibold text-sm transition">
                                            Baca Selengkapnya <i class="fas fa-arrow-right ml-2"></i>
                                        </a>
                                    </div>
                                <% } %>

                                <% if (user) { %>
                                    <a href="/daftar/<%= item.id %>" class="mt-6 w-full btn-primary text-white font-semibold py-3 rounded-lg transition flex items-center justify-center">
                                        <i class="fas fa-plus-circle mr-2"></i>Daftar Pendakian Sekarang
                                    </a>
                                <% } else { %>
                                    <a href="/login" class="mt-6 w-full btn-primary text-white font-semibold py-3 rounded-lg transition flex items-center justify-center">
                                        <i class="fas fa-sign-in-alt mr-2"></i>Login untuk Daftar
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        </section>
        <% } %>

        <!-- Footer -->
        <footer class="navbar-gradient text-white py-12">
            <div class="container mx-auto px-6">
                <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
                    <div>
                        <h4 class="text-lg font-bold mb-4 flex items-center"><i class="fas fa-mountain mr-2"></i>SIMAKSI</h4>
                        <p class="text-green-100 text-sm">Platform terpercaya untuk mendaftar pendakian gunung di Indonesia</p>
                    </div>
                    <div>
                        <h4 class="text-lg font-bold mb-4">Navigasi</h4>
                        <ul class="space-y-2 text-green-100 text-sm">
                            <li><a href="/beranda" class="hover:text-white transition">Beranda</a></li>
                            <li><a href="/berita" class="hover:text-white transition">Berita</a></li>
                            <li><a href="/pendakian" class="hover:text-white transition">Pendakian</a></li>
                            <li><a href="/kontak" class="hover:text-white transition">Kontak</a></li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="text-lg font-bold mb-4">Bantuan</h4>
                        <ul class="space-y-2 text-green-100 text-sm">
                            <li><a href="/faq" class="hover:text-white transition">FAQ</a></li>
                            <li><a href="/panduan" class="hover:text-white transition">Panduan Pendakian</a></li>
                            <li><a href="/keselamatan" class="hover:text-white transition">Keselamatan</a></li>
                            <li><a href="/syarat-ketentuan" class="hover:text-white transition">Syarat & Ketentuan</a></li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="text-lg font-bold mb-4">Hubungi Kami</h4>
                        <ul class="space-y-2 text-green-100 text-sm">
                            <li class="flex items-center"><i class="fas fa-phone mr-2"></i>+62 274 515 912</li>
                            <li class="flex items-center"><i class="fas fa-envelope mr-2"></i>info@simaksi.com</li>
                            <li class="flex items-center"><i class="fas fa-map-marker-alt mr-2"></i>Semarang, Indonesia</li>
                        </ul>
                    </div>
                </div>
                <div class="border-t border-green-700 pt-8 text-center text-green-100 text-sm">
                    <p>&copy; 2026 SIMAKSI - Sistem Informasi Manajemen Pendakian Gunung. All rights reserved.</p>
                </div>
            </div>
        </footer>
    </div>

    <!-- Scripts -->
    <script>
        // Profile dropdown functionality
        const profileBtn = document.getElementById('profile-btn');
        const profileDropdown = document.getElementById('profile-dropdown');

        if (profileBtn && profileDropdown) {
            profileBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                profileDropdown.classList.toggle('hidden');
            });

            // Close dropdown when clicking outside
            document.addEventListener('click', function(e) {
                if (!profileBtn.contains(e.target) && !profileDropdown.contains(e.target)) {
                    profileDropdown.classList.add('hidden');
                }
            });

            // Close dropdown on escape key
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    profileDropdown.classList.add('hidden');
                }
            });
        }
    </script>
</body>
</html>
