<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Bukti Pembayaran - SIMAKSI Gunung</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
      * { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
      .gradient-header { background: linear-gradient(135deg, #1e5631 0%, #2d7a3e 50%, #3a9f5d 100%); }
      .btn-submit { background: linear-gradient(135deg, #1e5631 0%, #3a9f5d 100%); transition: all 0.3s ease; }
      .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(30, 86, 49, 0.3); }
      .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; box-shadow: none; }
      .drop-zone { border: 3px dashed #cbd5e0; transition: all 0.3s ease; }
      .drop-zone.dragover { border-color: #1e5631; background-color: #f0fff4; }
      .drop-zone.has-file { border-color: #1e5631; background-color: #f0fff4; }
    </style>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">

    <!-- Navbar -->
    <header class="gradient-header text-white shadow-xl sticky top-0 z-50">
        <div class="container mx-auto flex justify-between items-center py-4 px-6">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center">
                    <i class="fas fa-mountain text-green-700 text-lg"></i>
                </div>
                <h1 class="text-2xl font-bold">SIMAKSI Gunung</h1>
            </div>
            <a href="/pembayaran/<%= pemesanan.kode_booking %>" class="text-white hover:text-green-200 transition">
                <i class="fas fa-arrow-left mr-2"></i>Kembali
            </a>
        </div>
    </header>

    <!-- Progress Steps -->
    <div class="bg-white shadow-sm border-b">
        <div class="container mx-auto px-6 py-4">
            <div class="flex items-center justify-center space-x-4">
                <div class="flex items-center">
                    <div class="w-8 h-8 rounded-full bg-green-600 text-white flex items-center justify-center font-bold text-sm">1</div>
                    <span class="ml-2 text-sm font-medium text-green-600">Formulir</span>
                </div>
                <div class="w-12 h-0.5 bg-green-600"></div>
                <div class="flex items-center">
                    <div class="w-8 h-8 rounded-full bg-green-600 text-white flex items-center justify-center font-bold text-sm">2</div>
                    <span class="ml-2 text-sm font-medium text-green-600">Pembayaran</span>
                </div>
                <div class="w-12 h-0.5 bg-green-600"></div>
                <div class="flex items-center">
                    <div class="w-8 h-8 rounded-full bg-green-600 text-white flex items-center justify-center font-bold text-sm pulse">3</div>
                    <span class="ml-2 text-sm font-medium text-green-600">Unggah Bukti</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container mx-auto px-6 py-10 max-w-3xl">
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
            <!-- Header -->
            <div class="gradient-header text-white p-6 text-center">
                <div class="w-16 h-16 bg-white bg-opacity-20 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-cloud-upload-alt text-3xl"></i>
                </div>
                <h2 class="text-2xl font-bold mb-2">Unggah Bukti Pembayaran</h2>
                <p class="text-green-100">Upload screenshot atau foto bukti transfer Anda</p>
            </div>

            <div class="p-8">
                <!-- Order Summary -->
                <div class="bg-gray-50 rounded-xl p-5 mb-6 border border-gray-200">
                    <h3 class="text-sm font-bold text-gray-900 mb-3 uppercase tracking-wide">Ringkasan Pesanan</h3>
                    <div class="grid grid-cols-2 gap-3 text-sm">
                        <div>
                            <p class="text-gray-500">Kode Booking</p>
                            <p class="font-mono font-bold text-green-700"><%= pemesanan.kode_booking %></p>
                        </div>
                        <div>
                            <p class="text-gray-500">Tujuan</p>
                            <p class="font-semibold"><%= pemesanan.nama_gunung %></p>
                        </div>
                        <div>
                            <p class="text-gray-500">Total Bayar</p>
                            <p class="font-bold text-lg text-green-700"><%= formatRupiah(pemesanan.total_bayar) %></p>
                        </div>
                        <div>
                            <p class="text-gray-500">Status</p>
                            <span class="inline-block px-3 py-1 text-xs font-bold rounded-full bg-yellow-100 text-yellow-800">
                                Menunggu Bukti
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Upload Form -->
                <form action="/upload-bukti/<%= pemesanan.kode_booking %>" method="POST" enctype="multipart/form-data" id="uploadForm">
                    
                    <!-- Drag & Drop Area -->
                    <div class="mb-6">
                        <label class="block text-gray-700 text-sm font-bold mb-2">
                            <i class="fas fa-image mr-1 text-green-600"></i>Bukti Pembayaran
                        </label>
                        <div id="dropZone" class="drop-zone rounded-xl p-10 text-center cursor-pointer hover:bg-gray-50">
                            <input type="file" id="fileInput" name="bukti_pembayaran" accept="image/jpeg,image/jpg,image/png,image/gif" class="hidden" required>
                            
                            <!-- Default state -->
                            <div id="uploadPrompt">
                                <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                                    <i class="fas fa-cloud-upload-alt text-green-600 text-3xl"></i>
                                </div>
                                <p class="text-lg font-semibold text-gray-700 mb-2">Drag & Drop file di sini</p>
                                <p class="text-sm text-gray-500 mb-4">atau klik untuk memilih file</p>
                                <p class="text-xs text-gray-400">
                                    <i class="fas fa-info-circle mr-1"></i>
                                    Format: JPG, PNG, GIF (Maks. 5MB)
                                </p>
                            </div>

                            <!-- File preview (hidden by default) -->
                            <div id="filePreview" class="hidden">
                                <img id="previewImage" src="" alt="Preview" class="max-h-64 mx-auto rounded-lg shadow-md mb-4">
                                <p id="fileName" class="text-sm font-medium text-green-700"></p>
                                <p id="fileSize" class="text-xs text-gray-500"></p>
                                <button type="button" id="removeFile" class="mt-3 text-sm text-red-600 hover:text-red-800 transition">
                                    <i class="fas fa-trash mr-1"></i>Hapus & Pilih Ulang
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Optional Notes -->
                    <div class="mb-6">
                        <label for="catatan" class="block text-gray-700 text-sm font-bold mb-2">
                            <i class="fas fa-sticky-note mr-1 text-green-600"></i>Catatan (Opsional)
                        </label>
                        <textarea id="catatan" name="catatan" rows="3" 
                                  placeholder="Tambahkan catatan jika diperlukan (contoh: transfer dari bank apa, nama pengirim, dll)"
                                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent resize-none"></textarea>
                    </div>

                    <!-- Info Box -->
                    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
                        <div class="flex items-start">
                            <i class="fas fa-info-circle text-blue-600 mt-1 mr-3"></i>
                            <div class="text-sm text-blue-800">
                                <p class="font-semibold mb-1">Setelah upload:</p>
                                <ul class="list-disc list-inside space-y-1">
                                    <li>Pemesanan Anda akan berstatus <strong>"Menunggu Verifikasi"</strong></li>
                                    <li>Admin akan memverifikasi bukti pembayaran dalam 1x24 jam</li>
                                    <li>Anda akan mendapat notifikasi di halaman status</li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex flex-col sm:flex-row gap-4">
                        <button type="submit" id="submitBtn" class="flex-1 btn-submit text-white font-bold py-4 px-6 rounded-xl flex items-center justify-center text-lg" disabled>
                            <i class="fas fa-paper-plane mr-2"></i>
                            Kirim Bukti Pembayaran
                        </button>
                        <a href="/pembayaran/<%= pemesanan.kode_booking %>" class="flex-1 bg-gray-200 text-gray-700 font-bold py-4 px-6 rounded-xl flex items-center justify-center text-lg hover:bg-gray-300 transition">
                            <i class="fas fa-times-circle mr-2"></i>
                            Batal
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="gradient-header text-white py-8 mt-12">
        <div class="container mx-auto px-6 text-center text-green-100 text-sm">
            <p>&copy; 2026 SIMAKSI - Sistem Informasi Manajemen Pendakian Gunung</p>
        </div>
    </footer>

    <!-- Upload & Preview Script -->
    <script>
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        const uploadPrompt = document.getElementById('uploadPrompt');
        const filePreview = document.getElementById('filePreview');
        const previewImage = document.getElementById('previewImage');
        const fileName = document.getElementById('fileName');
        const fileSize = document.getElementById('fileSize');
        const removeFile = document.getElementById('removeFile');
        const submitBtn = document.getElementById('submitBtn');

        // Click to upload
        dropZone.addEventListener('click', (e) => {
            if (e.target !== removeFile && !removeFile.contains(e.target)) {
                fileInput.click();
            }
        });

        // Drag & Drop
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('dragover');
        });

        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('dragover');
        });

        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('dragover');
            const files = e.dataTransfer.files;
            if (files.length > 0) {
                handleFile(files[0]);
            }
        });

        // File input change
        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                handleFile(e.target.files[0]);
            }
        });

        // Handle selected file
        function handleFile(file) {
            // Validate file type
            const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif'];
            if (!allowedTypes.includes(file.type)) {
                return;
            }

            // Validate file size (5MB)
            if (file.size > 5 * 1024 * 1024) {
                return;
            }

            // Show preview
            const reader = new FileReader();
            reader.onload = (e) => {
                previewImage.src = e.target.result;
                fileName.textContent = file.name;
                fileSize.textContent = (file.size / 1024).toFixed(2) + ' KB';
                uploadPrompt.classList.add('hidden');
                filePreview.classList.remove('hidden');
                dropZone.classList.add('has-file');
                submitBtn.disabled = false;
            };
            reader.readAsDataURL(file);
        }

        // Remove file
        removeFile.addEventListener('click', (e) => {
            e.stopPropagation();
            fileInput.value = '';
            previewImage.src = '';
            fileName.textContent = '';
            fileSize.textContent = '';
            uploadPrompt.classList.remove('hidden');
            filePreview.classList.add('hidden');
            dropZone.classList.remove('has-file');
            submitBtn.disabled = true;
        });
    </script>
</body>
</html>
