<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Beranda - Taman Nasional Gunung Merbabu</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="/css/output.css" rel="stylesheet">
</head>
<body>
    <div class="min-h-screen bg-gray-50">
        <!-- Navbar -->
        <header class="bg-green-800 text-white shadow-lg">
            <div class="container mx-auto flex justify-between items-center py-4 px-6">
                <h1 class="text-3xl font-extrabold tracking-wide">Taman Nasional Gunung Merbabu</h1>
                <nav>
                    <ul class="flex space-x-6 text-lg">
                        <li><a href="/" class="hover:text-green-300 transition duration-300">Home</a></li>
                        <li><a href="/berita" class="hover:text-green-300 transition duration-300">Berita</a></li>
                        <li><a href="/pendakian" class="hover:text-green-300 transition duration-300">Pendakian</a></li>
                        <li><a href="/kontak" class="hover:text-green-300 transition duration-300">Kontak</a></li>
                    </ul>
                </nav>
            </div>
        </header>

        <!-- Hero Section -->
        <section class="hero-section" style="background-image: url('https://via.placeholder.com/1920x1080');">
            <div class="text-white">
                <h2 class="text-5xl font-bold mb-4">Selamat Datang di Taman Nasional Gunung Merbabu</h2>
                <p class="text-xl">Menjaga kelestarian alam untuk generasi mendatang</p>
                <button class="mt-6 px-6 py-3 bg-green-600 hover:bg-green-500 text-white font-semibold rounded-lg shadow-md transition duration-300">Pelajari Lebih Lanjut</button>
            </div>
        </section>

        <!-- Informasi Section -->
        <section class="py-16 bg-white">
            <div class="container mx-auto px-6">
                <h3 class="text-3xl font-bold text-center mb-8 text-gray-800">Tentang Taman Nasional</h3>
                <p class="text-center text-gray-600 leading-relaxed text-lg">
                    Taman Nasional Gunung Merbabu adalah kawasan konservasi yang memiliki keindahan alam luar biasa. Dengan flora dan fauna yang beragam, taman nasional ini menjadi destinasi favorit bagi para pendaki dan pecinta alam.
                </p>
            </div>
        </section>

        <!-- Berita Terbaru Section -->
        <section class="py-16 bg-gray-100">
            <div class="container mx-auto px-6">
                <h3 class="text-3xl font-bold text-center mb-8 text-gray-800">Berita Terbaru</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <% berita.forEach(item => { %>
                        <div class="bg-white shadow-lg rounded-lg overflow-hidden hover:shadow-xl transition duration-300">
                            <img src="https://via.placeholder.com/400x200" alt="Berita" class="w-full h-48 object-cover">
                            <div class="p-6">
                                <h4 class="text-xl font-bold mb-2 text-gray-800"><%= item.judul %></h4>
                                <p class="text-sm text-gray-500 mb-4"><%= item.tanggal %></p>
                                <a href="/berita/<%= item.id %>" class="text-green-700 hover:underline">Baca Selengkapnya</a>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        </section>

        <!-- Pilih Tujuan Pendakian Section -->
        <section class="py-16 bg-white">
            <div class="container mx-auto px-6">
                <h3 class="text-3xl font-bold text-center mb-8 text-gray-800">Pilih Tujuan Pendakian</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <!-- Gunung Merbabu -->
                    <div class="bg-white shadow-lg rounded-lg overflow-hidden hover:shadow-xl transition duration-300">
                        <img src="https://via.placeholder.com/400x200" alt="Gunung Merbabu" class="w-full h-48 object-cover">
                        <div class="p-6">
                            <h4 class="text-xl font-bold mb-2 text-gray-800">Gunung Merbabu</h4>
                            <button class="mt-4 px-4 py-2 bg-green-600 hover:bg-green-500 text-white font-semibold rounded-lg shadow-md transition duration-300">Lihat Detail</button>
                        </div>
                    </div>
                    <!-- Gunung Merapi -->
                    <div class="bg-white shadow-lg rounded-lg overflow-hidden hover:shadow-xl transition duration-300">
                        <img src="https://via.placeholder.com/400x200" alt="Gunung Merapi" class="w-full h-48 object-cover">
                        <div class="p-6">
                            <h4 class="text-xl font-bold mb-2 text-gray-800">Gunung Merapi</h4>
                            <button class="mt-4 px-4 py-2 bg-green-600 hover:bg-green-500 text-white font-semibold rounded-lg shadow-md transition duration-300">Lihat Detail</button>
                        </div>
                    </div>
                    <!-- Gunung Lawu -->
                    <div class="bg-white shadow-lg rounded-lg overflow-hidden hover:shadow-xl transition duration-300">
                        <img src="https://via.placeholder.com/400x200" alt="Gunung Lawu" class="w-full h-48 object-cover">
                        <div class="p-6">
                            <h4 class="text-xl font-bold mb-2 text-gray-800">Gunung Lawu</h4>
                            <button class="mt-4 px-4 py-2 bg-green-600 hover:bg-green-500 text-white font-semibold rounded-lg shadow-md transition duration-300">Lihat Detail</button>
                        </div>
                    </div>
                    <!-- Gunung Sindoro -->
                    <div class="bg-white shadow-lg rounded-lg overflow-hidden hover:shadow-xl transition duration-300">
                        <img src="https://via.placeholder.com/400x200" alt="Gunung Sindoro" class="w-full h-48 object-cover">
                        <div class="p-6">
                            <h4 class="text-xl font-bold mb-2 text-gray-800">Gunung Sindoro</h4>
                            <button class="mt-4 px-4 py-2 bg-green-600 hover:bg-green-500 text-white font-semibold rounded-lg shadow-md transition duration-300">Lihat Detail</button>
                        </div>
                    </div>
                    <!-- Gunung Sumbing -->
                    <div class="bg-white shadow-lg rounded-lg overflow-hidden hover:shadow-xl transition duration-300">
                        <img src="https://via.placeholder.com/400x200" alt="Gunung Sumbing" class="w-full h-48 object-cover">
                        <div class="p-6">
                            <h4 class="text-xl font-bold mb-2 text-gray-800">Gunung Sumbing</h4>
                            <button class="mt-4 px-4 py-2 bg-green-600 hover:bg-green-500 text-white font-semibold rounded-lg shadow-md transition duration-300">Lihat Detail</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="bg-green-800 text-white py-8">
            <div class="container mx-auto text-center">
                <p class="text-lg">&copy; 2026 Taman Nasional Gunung Merbabu. All rights reserved.</p>
                <div class="flex justify-center space-x-4 mt-4">
                    <a href="#" class="hover:text-green-300 transition duration-300">Facebook</a>
                    <a href="#" class="hover:text-green-300 transition duration-300">Instagram</a>
                    <a href="#" class="hover:text-green-300 transition duration-300">YouTube</a>
                </div>
            </div>
        </footer>
    </div>
</body>
</html>