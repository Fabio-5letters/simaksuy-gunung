<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Beranda - SIMAKSI Gunung Merbabu</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
      * {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      }
      .navbar-gradient {
        background: linear-gradient(135deg, #1e5631 0%, #2d7a3e 50%, #3a9f5d 100%);
      }
      .hero-section {
        background: linear-gradient(rgba(30, 86, 49, 0.7), rgba(30, 86, 49, 0.7)), url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1920&h=1080&fit=crop');
        background-size: cover;
        background-position: center;
      }
      .card-hover {
        transition: all 0.3s ease;
      }
      .card-hover:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(30, 86, 49, 0.15);
      }
      .btn-cta {
        background: linear-gradient(135deg, #1e5631 0%, #3a9f5d 100%);
        transition: all 0.3s ease;
      }
      .btn-cta:hover {
        transform: scale(1.05);
        box-shadow: 0 10px 25px rgba(30, 86, 49, 0.3);
      }
    </style>
    <link rel="stylesheet" href="/css/style.css">
    <link href="/css/output.css" rel="stylesheet">
</head>
<body class="bg-white">
    <% const defaultMountainImage = 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=900&h=600&fit=crop'; %>
    <% const mountainImages = gunung ? Object.fromEntries(gunung.map(g => [g.nama_gunung, g.gambar || defaultMountainImage])) : {}; %>
    <div class="min-h-screen">
        <!-- Navbar -->
        <header class="navbar-gradient text-white shadow-xl sticky top-0 z-50">
            <div class="container mx-auto flex justify-between items-center py-4 px-6">
                <div class="flex items-center space-x-3">
                    <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center">
                        <i class="fas fa-mountain text-green-700 text-lg"></i>
                    </div>
                    <h1 class="text-2xl font-bold">SIMAKSI Gunung</h1>
                </div>
                <nav class="hidden md:block">
                    <ul class="flex space-x-8 font-semibold">
                        <li><a href="/" class="hover:text-green-200 transition duration-300 flex items-center space-x-2"><i class="fas fa-home"></i><span>Beranda</span></a></li>
                        <li><a href="/berita" class="hover:text-green-200 transition duration-300 flex items-center space-x-2"><i class="fas fa-newspaper"></i><span>Berita</span></a></li>
                        <li><a href="/pendakian" class="hover:text-green-200 transition duration-300 flex items-center space-x-2"><i class="fas fa-person-hiking"></i><span>Pendakian</span></a></li>
                        <li><a href="/cuaca" class="hover:text-green-200 transition duration-300 flex items-center space-x-2"><i class="fas fa-cloud-sun"></i><span>Cuaca</span></a></li>
                        <li><a href="/status" class="hover:text-green-200 transition duration-300 flex items-center space-x-2"><i class="fas fa-chart-line"></i><span>Status</span></a></li>
                        <li><a href="/panduan" class="hover:text-green-200 transition duration-300 flex items-center space-x-2"><i class="fas fa-download"></i><span>Panduan</span></a></li>
                        <li><a href="/kontak" class="hover:text-green-200 transition duration-300 flex items-center space-x-2"><i class="fas fa-envelope"></i><span>Kontak</span></a></li>
                    </ul>
                </nav>
                <div class="flex space-x-4">
                    <% if (user) { %>
                        <!-- User Profile Dropdown -->
                        <div class="relative">
                            <button id="profile-btn" class="flex items-center space-x-3 bg-white text-green-700 px-4 py-2 rounded-lg font-semibold hover:bg-green-50 transition">
                                <div class="w-8 h-8 bg-green-600 rounded-full flex items-center justify-center">
                                    <i class="fas fa-user text-white text-sm"></i>
                                </div>
                                <span><%= user.nama %></span>
                                <i class="fas fa-chevron-down text-sm"></i>
                            </button>
                            <div id="profile-dropdown" class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg border border-gray-200 hidden z-50">
                                <div class="py-2">
                                    <div class="px-4 py-2 border-b border-gray-100">
                                        <p class="text-sm font-medium text-gray-900"><%= user.nama %></p>
                                        <p class="text-xs text-gray-500"><%= user.email %></p>
                                    </div>
                                    <a href="/profile" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition">
                                        <i class="fas fa-user-circle mr-2"></i>Profile Saya
                                    </a>
                                    <a href="/riwayat" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition">
                                        <i class="fas fa-history mr-2"></i>Riwayat Pendakian
                                    </a>
                                    <div class="border-t border-gray-100"></div>
                                    <a href="/logout" class="block px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition">
                                        <i class="fas fa-sign-out-alt mr-2"></i>Logout
                                    </a>
                                </div>
                            </div>
                        </div>
                    <% } else { %>
                        <a href="/login" class="bg-white text-green-700 px-6 py-2 rounded-lg font-semibold hover:bg-green-50 transition">Login</a>
                    <% } %>
                </div>
            </div>
        </header>

        <!-- Hero Section -->
        <section class="hero-section min-h-96 flex items-center justify-center text-white py-20 px-6">
            <div class="text-center max-w-2xl">
                <h2 class="text-5xl md:text-6xl font-black mb-6 drop-shadow-lg">Jelajahi Keindahan Alam</h2>
                <p class="text-xl md:text-2xl mb-8 drop-shadow-md">Daftar pendakian gunung favorit Anda dan rasakan petualangan yang tak terlupakan</p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <button class="btn-cta px-8 py-4 text-white font-bold rounded-lg text-lg shadow-lg">
                        <i class="fas fa-arrow-right mr-2"></i>Mulai Sekarang
                    </button>
                    <button class="px-8 py-4 bg-white text-green-700 font-bold rounded-lg text-lg hover:bg-gray-100 transition">
                        <i class="fas fa-info-circle mr-2"></i>Pelajari Lebih Lanjut
                    </button>
                </div>
            </div>
        </section>

        <!-- Informasi Section -->
        <section class="py-20 bg-gradient-to-b from-white to-green-50">
            <div class="container mx-auto px-6">
                <div class="max-w-3xl mx-auto">
                    <h3 class="text-4xl font-bold text-center mb-6 text-green-900">Tentang Taman Nasional</h3>
                    <div class="bg-gradient-to-r from-green-100 to-emerald-100 rounded-2xl p-8 shadow-lg">
                        <p class="text-center text-gray-700 leading-relaxed text-lg">
                            Taman Nasional Gunung Merbabu adalah kawasan konservasi yang memiliki keindahan alam luar biasa. Dengan flora dan fauna yang beragam, taman nasional ini menjadi destinasi favorit bagi para pendaki dan pecinta alam. Kami berkomitmen menjaga kelestarian alam untuk generasi mendatang.
                        </p>
                    </div>
                    <!-- Stats -->
                    <div class="grid grid-cols-3 gap-4 mt-8">
                        <div class="text-center">
                            <div class="text-3xl font-bold text-green-700">3000+</div>
                            <p class="text-gray-600 text-sm">Pendaki per Bulan</p>
                        </div>
                        <div class="text-center">
                            <div class="text-3xl font-bold text-green-700">4</div>
                            <p class="text-gray-600 text-sm">Gunung Pilihan</p>
                        </div>
                        <div class="text-center">
                            <div class="text-3xl font-bold text-green-700">24/7</div>
                            <p class="text-gray-600 text-sm">Dukungan Pelanggan</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Fitur Utama Sistem -->
        <section class="py-20 bg-white">
            <div class="container mx-auto px-6">
                <div class="text-center mb-12">
                    <h3 class="text-4xl font-bold text-gray-900 mb-4">Fitur Utama Sistem</h3>
                    <p class="text-gray-600 text-lg">Akses cepat ke informasi dan layanan pendakian</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                    <!-- Informasi Cuaca -->
                    <div class="card-hover group">
                        <div class="bg-gradient-to-br from-blue-500 to-blue-700 rounded-xl p-8 text-white text-center shadow-lg">
                            <div class="w-16 h-16 bg-white bg-opacity-20 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition">
                                <i class="fas fa-cloud-sun text-3xl"></i>
                            </div>
                            <h4 class="text-xl font-bold mb-2">Informasi Cuaca</h4>
                            <p class="text-blue-100 mb-4">Pantau kondisi cuaca terkini di setiap gunung</p>
                            <button onclick="window.location.href='/cuaca'" class="bg-white text-blue-700 px-6 py-2 rounded-lg font-semibold hover:bg-blue-50 transition">
                                Lihat Cuaca
                            </button>
                        </div>
                    </div>

                    <!-- Riwayat Pendakian -->
                    <div class="card-hover group">
                        <div class="bg-gradient-to-br from-green-500 to-green-700 rounded-xl p-8 text-white text-center shadow-lg">
                            <div class="w-16 h-16 bg-white bg-opacity-20 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition">
                                <i class="fas fa-history text-3xl"></i>
                            </div>
                            <h4 class="text-xl font-bold mb-2">Riwayat Pendakian</h4>
                            <p class="text-green-100 mb-4">Lihat catatan lengkap pendakian Anda sebelumnya</p>
                            <button onclick="window.location.href='/riwayat'" class="bg-white text-green-700 px-6 py-2 rounded-lg font-semibold hover:bg-green-50 transition">
                                Lihat Riwayat
                            </button>
                        </div>
                    </div>

                    <!-- Status Pendakian -->
                    <div class="card-hover group">
                        <div class="bg-gradient-to-br from-orange-500 to-orange-700 rounded-xl p-8 text-white text-center shadow-lg">
                            <div class="w-16 h-16 bg-white bg-opacity-20 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition">
                                <i class="fas fa-chart-line text-3xl"></i>
                            </div>
                            <h4 class="text-xl font-bold mb-2">Status Pendakian</h4>
                            <p class="text-orange-100 mb-4">Monitor status pengajuan dan persetujuan pendakian</p>
                            <button onclick="window.location.href='/status'" class="bg-white text-orange-700 px-6 py-2 rounded-lg font-semibold hover:bg-orange-50 transition">
                                Cek Status
                            </button>
                        </div>
                    </div>

                    <!-- Download Panduan -->
                    <div class="card-hover group">
                        <div class="bg-gradient-to-br from-purple-500 to-purple-700 rounded-xl p-8 text-white text-center shadow-lg">
                            <div class="w-16 h-16 bg-white bg-opacity-20 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition">
                                <i class="fas fa-download text-3xl"></i>
                            </div>
                            <h4 class="text-xl font-bold mb-2">Download Panduan</h4>
                            <p class="text-purple-100 mb-4">Unduh panduan lengkap untuk pendakian yang aman</p>
                            <button onclick="window.location.href='/panduan'" class="bg-white text-purple-700 px-6 py-2 rounded-lg font-semibold hover:bg-purple-50 transition">
                                Download
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Berita Terbaru Section -->
        <section class="py-20 bg-gray-50">
            <div class="container mx-auto px-6">
                <div class="text-center mb-12">
                    <h3 class="text-4xl font-bold text-gray-900 mb-4">Berita Terbaru</h3>
                    <p class="text-gray-600 text-lg">Informasi terkini tentang aktivitas dan kondisi gunung</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <% berita.forEach(item => { %>
                        <div class="card-hover bg-white rounded-xl overflow-hidden">
                            <div class="h-48 overflow-hidden bg-gradient-to-br from-green-400 to-green-600">
                                <img src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=500&h=300&fit=crop" alt="Berita" class="w-full h-full object-cover opacity-80">
                            </div>
                            <div class="p-6">
                                <div class="flex items-center space-x-2 mb-3">
                                    <i class="fas fa-calendar text-green-600 text-sm"></i>
                                    <p class="text-sm text-gray-500"><%= item.tanggal %></p>
                                </div>
                                <h4 class="text-lg font-bold mb-3 text-gray-900 line-clamp-2"><%= item.judul %></h4>
                                <a href="/berita/<%= item.id %>" class="inline-flex items-center text-green-600 hover:text-green-700 font-semibold transition">
                                    Baca Selengkapnya <i class="fas fa-arrow-right ml-2"></i>
                                </a>
                            </div>
                        </div>
                    <% }); %>
                </div>
            </div>
        </section>

        <!-- Pilih Tujuan Pendakian Section -->
        <section class="py-20 bg-white">
            <div class="container mx-auto px-6">
                <div class="text-center mb-12">
                    <h3 class="text-4xl font-bold text-gray-900 mb-4">Pilih Tujuan Pendakian</h3>
                    <p class="text-gray-600 text-lg">Jelajahi berbagai puncak gunung yang menakjubkan</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <% if (gunung && gunung.length > 0) { %>
                        <% gunung.forEach(item => { %>
                            <div class="card-hover group">
                                <div class="relative overflow-hidden rounded-xl shadow-lg">
                                    <div class="h-56 bg-gradient-to-br from-green-400 to-green-600 overflow-hidden">
                                        <img src="<%= mountainImages[item.nama_gunung] || defaultMountainImage %>" alt="<%= item.nama_gunung %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                                    </div>
                                    <div class="absolute inset-0 bg-black bg-opacity-30 group-hover:bg-opacity-20 transition"></div>
                                    <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black to-transparent p-6 text-white">
                                        <div class="flex items-center justify-between">
                                            <div>
                                                <h4 class="text-2xl font-bold"><%= item.nama_gunung %></h4>
                                                <p class="text-sm text-gray-300 flex items-center mt-1"><i class="fas fa-map-marker-alt mr-1"></i><%= item.lokasi %></p>
                                                <p class="text-sm text-gray-300 flex items-center mt-1"><i class="fas fa-arrow-up mr-1"></i><%= item.ketinggian %> mdpl</p>
                                            </div>
                                            <i class="fas fa-mountain text-3xl opacity-30"></i>
                                        </div>
                                        <button onclick="showGunungDetail(<%= item.id %>)" class="mt-4 w-full <%= item.status === 'Buka' ? 'bg-green-600 hover:bg-green-700' : 'bg-gray-600 hover:bg-gray-700' %> text-white font-semibold py-2 rounded-lg transition flex items-center justify-center">
                                            <i class="fas fa-info-circle mr-2"></i>Lihat Detail
                                        </button>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="col-span-full text-center py-20">
                            <i class="fas fa-mountain text-6xl text-gray-300 mb-4"></i>
                            <h3 class="text-2xl font-bold text-gray-600 mb-2">Belum ada gunung tersedia</h3>
                            <p class="text-gray-500">Data gunung akan segera ditambahkan oleh admin.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </section>

        <div id="detailModal" class="fixed inset-0 bg-black bg-opacity-60 hidden z-50 items-center justify-center px-4">
            <div class="bg-white rounded-3xl overflow-hidden max-w-3xl w-full shadow-2xl">
                <div class="lg:flex lg:items-start">
                    <div class="lg:w-1/2 h-72 lg:h-auto bg-gray-200 overflow-hidden">
                        <img id="detailModalImage" src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=900&h=600&fit=crop" alt="Gunung" class="w-full h-full object-cover">
                    </div>
                    <div class="lg:w-1/2">
                        <div class="flex justify-between items-center p-6 border-b border-gray-200">
                            <div>
                                <h3 id="detailTitle" class="text-3xl font-bold text-gray-900"></h3>
                                <p id="detailSubtitle" class="text-sm text-gray-500 mt-1"></p>
                            </div>
                            <button onclick="closeDetailModal()" class="text-gray-400 hover:text-gray-700">
                                <i class="fas fa-times text-2xl"></i>
                            </button>
                        </div>
                <div class="p-6 grid gap-6 md:grid-cols-2">
                    <div>
                        <p id="detailDescription" class="text-gray-700 leading-relaxed"></p>
                    </div>
                    <div class="space-y-4">
                        <div class="bg-green-50 rounded-2xl p-4">
                            <p class="text-sm text-gray-600">Lokasi</p>
                            <p id="detailLocation" class="font-semibold text-gray-900"></p>
                        </div>
                        <div class="bg-green-50 rounded-2xl p-4">
                            <p class="text-sm text-gray-600">Ketinggian</p>
                            <p id="detailHeight" class="font-semibold text-gray-900"></p>
                        </div>
                        <div class="bg-green-50 rounded-2xl p-4">
                            <p class="text-sm text-gray-600">Kuota Harian</p>
                            <p id="detailQuota" class="font-semibold text-gray-900"></p>
                        </div>
                        <div class="bg-green-50 rounded-2xl p-4">
                            <p class="text-sm text-gray-600">Status</p>
                            <p id="detailStatus" class="font-semibold text-gray-900"></p>
                        </div>
                    </div>
                </div>
                <div class="bg-gray-50 p-6 text-right">
                    <button onclick="closeDetailModal()" class="px-6 py-3 rounded-full bg-green-600 text-white font-semibold hover:bg-green-700 transition">
                        Tutup
                    </button>
                </div>
            </div>
        </div>

        <!-- CTA Section -->
        <section class="py-20 bg-gradient-to-r from-green-600 to-green-800">
            <div class="container mx-auto px-6 text-center">
                <h3 class="text-4xl font-bold text-white mb-4">Siap untuk Petualangan?</h3>
                <p class="text-xl text-green-100 mb-8">Daftar sekarang dan mulai pendakian impian Anda bersama kami</p>
                <button class="px-10 py-4 bg-white text-green-700 font-bold text-lg rounded-lg hover:bg-gray-100 transition shadow-lg">
                    <i class="fas fa-rocket mr-2"></i>Mulai Sekarang
                </button>
            </div>
        </section>

        <!-- Footer -->
        <footer class="navbar-gradient text-white py-12">
            <div class="container mx-auto px-6">
                <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
                    <div>
                        <h4 class="text-lg font-bold mb-4 flex items-center"><i class="fas fa-mountain mr-2"></i>SIMAKSI</h4>
                        <p class="text-green-100 text-sm">Platform terpercaya untuk mendaftar pendakian gunung di Indonesia</p>
                    </div>
                    <div>
                        <h4 class="text-lg font-bold mb-4">Navigasi</h4>
                        <ul class="space-y-2 text-green-100 text-sm">
                            <li><a href="/" class="hover:text-white transition">Beranda</a></li>
                            <li><a href="/berita" class="hover:text-white transition">Berita</a></li>
                            <li><a href="/pendakian" class="hover:text-white transition">Pendakian</a></li>
                            <li><a href="/kontak" class="hover:text-white transition">Kontak</a></li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="text-lg font-bold mb-4">Bantuan</h4>
                        <ul class="space-y-2 text-green-100 text-sm">
                            <li><a href="/faq" class="hover:text-white transition">FAQ</a></li>
                            <li><a href="/panduan" class="hover:text-white transition">Panduan Pendakian</a></li>
                            <li><a href="/keselamatan" class="hover:text-white transition">Keselamatan</a></li>
                            <li><a href="/syarat-ketentuan" class="hover:text-white transition">Syarat & Ketentuan</a></li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="text-lg font-bold mb-4">Hubungi Kami</h4>
                        <ul class="space-y-2 text-green-100 text-sm">
                            <li class="flex items-center"><i class="fas fa-phone mr-2"></i>+62 274 515 912</li>
                            <li class="flex items-center"><i class="fas fa-envelope mr-2"></i>info@simaksi.com</li>
                            <li class="flex items-center"><i class="fas fa-map-marker-alt mr-2"></i>Semarang, Indonesia</li>
                        </ul>
                    </div>
                </div>
                <div class="border-t border-green-700 pt-8 text-center text-green-100 text-sm">
                    <p>&copy; 2026 SIMAKSI - Sistem Informasi Manajemen Pendakian Gunung. All rights reserved.</p>
                    <div class="flex justify-center space-x-4 mt-4">
                        <a href="#" class="hover:text-white transition"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="hover:text-white transition"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="hover:text-white transition"><i class="fab fa-youtube"></i></a>
                        <a href="#" class="hover:text-white transition"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>
            </div>
        </footer>
    </div>

    <!-- Profile Dropdown Script -->
    <script>
        // Profile dropdown functionality
        const profileBtn = document.getElementById('profile-btn');
        const profileDropdown = document.getElementById('profile-dropdown');

        if (profileBtn && profileDropdown) {
            profileBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                profileDropdown.classList.toggle('hidden');
            });

            // Close dropdown when clicking outside
            document.addEventListener('click', function(e) {
                if (!profileBtn.contains(e.target) && !profileDropdown.contains(e.target)) {
                    profileDropdown.classList.add('hidden');
                }
            });

            // Close dropdown on escape key
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    profileDropdown.classList.add('hidden');
                }
            });
        }

        const mountainData = <%- JSON.stringify(gunung || []) %>;
        const mountainDescriptions = {
            'Gunung Merbabu': 'Gunung Merbabu terkenal dengan pemandangan sunrise yang spektakuler dan jalur pendakian yang menantang namun terawat. Cocok untuk pendaki yang ingin merasakan suasana alam Jawa Tengah.',
            'Gunung Merapi': 'Gunung Merapi adalah gunung berapi aktif di Jawa Tengah yang menawarkan pengalaman pendakian penuh adrenalin. Pastikan mematuhi aturan keselamatan dan jadwal bukanya.',
            'Gunung Lawu': 'Gunung Lawu memiliki rute pendakian yang indah dengan jalur campuran hutan dan bukit, cocok untuk pendaki pemula dan menengah.',
            'Gunung Sindoro': 'Gunung Sindoro dikenal dengan pemandangan alam hijau dan udara sejuk. Nikmati sunrise dari puncak serta panorama lereng yang memukau.',
            'Semeru': 'Gunung Semeru adalah puncak tertinggi di Pulau Jawa dengan danau kawah yang indah dan rute pendakian yang menantang. Persiapkan fisik dan peralatan dengan matang.',
            'Gede Pangrango': 'Gunung Gede Pangrango menghadirkan pemandangan hutan tropis, padang edelweiss, dan jalur yang cocok untuk pendakian akhir pekan.',
            'Bromo': 'Gunung Bromo terkenal dengan lautan pasir yang menakjubkan dan matahari terbit spektakuler. Gunakan rute yang aman saat menjelajah kawasan Bromo-Tengger-Semeru.',
            'Slamet': 'Gunung Slamet menawarkan panorama alam liar dan jalur pendakian yang panjang. Sesuaikan dengan kemampuan fisik dan bawa bekal cukup.',
            'Ciremai': 'Gunung Ciremai memiliki rute pendakian yang sejuk dan pemandangan hutan yang rimbun. Cocok untuk pendaki yang ingin menikmati suasana alam pegunungan di Jawa Barat.'
        };
        
        // Use gambar from database if available
        function getMountainImage(gunung) {
            if (gunung.gambar) return gunung.gambar;
            // Fallback to hardcoded images
            const fallbackImages = {
                'Gunung Merbabu': 'https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?w=900&h=600&fit=crop',
                'Gunung Merapi': 'https://images.unsplash.com/photo-1547691880-8be24c97feaa?w=900&h=600&fit=crop',
                'Gunung Lawu': 'https://images.unsplash.com/photo-1519817650390-64a93db511f0?w=900&h=600&fit=crop',
                'Gunung Sindoro': 'https://images.unsplash.com/photo-1535947257809-aaa1f79a0e7f?w=900&h=600&fit=crop',
                'Semeru': 'https://images.unsplash.com/photo-1516762689617-3a5bb5a2c8bb?w=900&h=600&fit=crop',
                'Gede Pangrango': 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=900&h=600&fit=crop',
                'Bromo': 'https://images.unsplash.com/photo-1501785888041-af3ef285b470?w=900&h=600&fit=crop',
                'Slamet': 'https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?w=900&h=600&fit=crop',
                'Ciremai': 'https://images.unsplash.com/photo-1518831952650-8f0549e89687?w=900&h=600&fit=crop'
            };
            return fallbackImages[gunung.nama_gunung] || defaultMountainImage;
        }

        const defaultMountainImage = 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=900&h=600&fit=crop';

        function getGunungDescription(name) {
            return mountainDescriptions[name] || 'Gunung ini menawarkan lanskap indah dan pengalaman pendakian yang menarik di Pulau Jawa.';
        }

        function showGunungDetail(id) {
            const item = mountainData.find(g => g.id === id);
            if (!item) return;

            document.getElementById('detailModalImage').src = mountainImages[item.nama_gunung] || defaultMountainImage;
            document.getElementById('detailModalImage').alt = item.nama_gunung;
            document.getElementById('detailTitle').innerText = item.nama_gunung;
            document.getElementById('detailSubtitle').innerText = item.lokasi;
            document.getElementById('detailLocation').innerText = item.lokasi;
            document.getElementById('detailHeight').innerText = `${item.ketinggian} mdpl`;
            document.getElementById('detailQuota').innerText = `${item.kuota_harian} orang`;
            document.getElementById('detailStatus').innerText = item.status;
            document.getElementById('detailDescription').innerText = item.deskripsi || getGunungDescription(item.nama_gunung);
            document.getElementById('detailModal').classList.remove('hidden');
        }

        function closeDetailModal() {
            document.getElementById('detailModal').classList.add('hidden');
        }

        const detailModal = document.getElementById('detailModal');
        if (detailModal) {
            detailModal.addEventListener('click', function(e) {
                if (e.target === this) {
                    closeDetailModal();
                }
            });
        }
    </script>
</body>
</html>