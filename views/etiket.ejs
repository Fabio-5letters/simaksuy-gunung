<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>E-Tiket - <%= pemesanan.kode_booking %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
      @media print {
        .no-print {
          display: none !important;
        }
        body {
          background: white;
        }
      }
      .etiket {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        position: relative;
        overflow: hidden;
      }
      .etiket::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
        animation: pulse 15s ease-in-out infinite;
      }
      @keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
      }
      .barcode {
        font-family: 'Libre Barcode 39', cursive;
        font-size: 48px;
      }
    </style>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Barcode+39&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-100 min-h-screen">
    <!-- Action Buttons -->
    <div class="no-print bg-white shadow-lg p-4 sticky top-0 z-50">
        <div class="container mx-auto max-w-4xl flex justify-between items-center">
            <h3 class="text-lg font-bold text-gray-800">E-Tiket Pendakian</h3>
            <div class="flex space-x-3">
                <button onclick="window.print()" class="bg-gradient-to-r from-blue-600 to-purple-600 text-white px-6 py-2 rounded-lg font-semibold hover:shadow-lg transition">
                    <i class="fas fa-print mr-2"></i>Cetak E-Tiket
                </button>
                <a href="/riwayat" class="bg-gray-200 text-gray-700 px-6 py-2 rounded-lg font-semibold hover:bg-gray-300 transition">
                    <i class="fas fa-arrow-left mr-2"></i>Kembali
                </a>
            </div>
        </div>
    </div>

    <!-- E-Tiket -->
    <div class="container mx-auto px-6 py-12">
        <div class="max-w-4xl mx-auto">
            <div class="etiket text-white rounded-3xl shadow-2xl p-8 md:p-12 relative">
                <!-- Header -->
                <div class="relative z-10 text-center mb-8">
                    <div class="flex items-center justify-center mb-4">
                        <i class="fas fa-mountain text-5xl mr-4"></i>
                        <div>
                            <h1 class="text-4xl md:text-5xl font-black">SIMAKSI</h1>
                            <p class="text-lg opacity-90">Sistem Informasi Manajemen Pendakian Gunung</p>
                        </div>
                    </div>
                    <div class="inline-block bg-white bg-opacity-20 backdrop-blur-sm px-6 py-2 rounded-full">
                        <span class="text-sm font-semibold">E-TIKET PENDAKIAN</span>
                    </div>
                </div>

                <!-- Ticket Content -->
                <div class="relative z-10 bg-white bg-opacity-10 backdrop-blur-sm rounded-2xl p-8 mb-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <!-- Left Column -->
                        <div class="space-y-4">
                            <div>
                                <p class="text-sm opacity-80">Kode Booking</p>
                                <p class="text-2xl font-bold font-mono"><%= pemesanan.kode_booking %></p>
                            </div>
                            <div>
                                <p class="text-sm opacity-80">Nama Pendaki</p>
                                <p class="text-xl font-bold"><%= pemesanan.nama_user %></p>
                            </div>
                            <div>
                                <p class="text-sm opacity-80">Email</p>
                                <p class="text-base"><%= pemesanan.email_user %></p>
                            </div>
                            <div>
                                <p class="text-sm opacity-80">Nomor HP</p>
                                <p class="text-base"><%= pemesanan.nomor_hp %></p>
                            </div>
                        </div>

                        <!-- Right Column -->
                        <div class="space-y-4">
                            <div>
                                <p class="text-sm opacity-80">Gunung Tujuan</p>
                                <p class="text-2xl font-bold"><%= pemesanan.nama_gunung %></p>
                                <p class="text-sm opacity-80"><%= pemesanan.lokasi %> • <%= pemesanan.ketinggian %> mdpl</p>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <p class="text-sm opacity-80">Tanggal Masuk</p>
                                    <p class="text-lg font-bold"><%= new Date(pemesanan.tanggal_masuk).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                                </div>
                                <div>
                                    <p class="text-sm opacity-80">Tanggal Keluar</p>
                                    <p class="text-lg font-bold"><%= new Date(pemesanan.tanggal_keluar).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                                </div>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <p class="text-sm opacity-80">Pintu Masuk</p>
                                    <p class="text-lg font-bold"><%= pemesanan.pintu_masuk %></p>
                                </div>
                                <div>
                                    <p class="text-sm opacity-80">Pintu Keluar</p>
                                    <p class="text-lg font-bold"><%= pemesanan.pintu_keluar %></p>
                                </div>
                            </div>
                            <div>
                                <p class="text-sm opacity-80">Jumlah Anggota</p>
                                <p class="text-xl font-bold"><%= pemesanan.jumlah_anggota %> Orang</p>
                            </div>
                        </div>
                    </div>

                    <!-- Payment Info -->
                    <div class="mt-8 pt-6 border-t border-white border-opacity-20">
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div>
                                <p class="text-sm opacity-80">Total Pembayaran</p>
                                <p class="text-2xl font-bold">Rp <%= parseInt(pemesanan.total_bayar).toLocaleString('id-ID') %></p>
                            </div>
                            <div>
                                <p class="text-sm opacity-80">Status Pembayaran</p>
                                <div class="inline-block bg-green-500 px-4 py-1 rounded-full text-sm font-bold mt-1">
                                    <i class="fas fa-check-circle mr-1"></i>TERVERIFIKASI
                                </div>
                            </div>
                            <div>
                                <p class="text-sm opacity-80">Tanggal Terbit</p>
                                <p class="text-lg font-bold"><%= new Date(pemesanan.updated_at || pemesanan.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- QR Code Placeholder -->
                <div class="relative z-10 bg-white rounded-2xl p-6 text-center">
                    <div class="barcode text-purple-600 mb-2">
                        *<%= pemesanan.kode_booking %>*
                    </div>
                    <p class="text-gray-600 text-sm font-mono"><%= pemesanan.kode_booking %></p>
                    <p class="text-gray-500 text-xs mt-2">Tunjukkan E-Tiket ini di pos pendakian</p>
                </div>

                <!-- Terms & Conditions -->
                <div class="relative z-10 mt-8 text-center text-sm opacity-80">
                    <p class="font-bold mb-2">Syarat & Ketentuan</p>
                    <ul class="text-xs space-y-1">
                        <li>• E-Tiket ini hanya berlaku untuk satu kali pendakian</li>
                        <li>• Wajib membawa kartu identitas (KTP/SIM/Paspor)</li>
                        <li>• Mematuhi semua aturan dan regulasi pendakian</li>
                        <li>• Menjaga kebersihan dan kelestarian alam</li>
                        <li>• E-Tiket yang sudah diverifikasi tidak dapat dikembalikan</li>
                    </ul>
                </div>
            </div>

            <!-- Footer Info -->
            <div class="mt-8 text-center text-gray-600 no-print">
                <p class="text-sm">
                    <i class="fas fa-info-circle mr-1"></i>
                    E-Tiket ini adalah bukti resmi bahwa Anda telah terdaftar dan pembayaran telah diverifikasi
                </p>
                <p class="text-xs mt-2 text-gray-500">
                    Diterbitkan oleh SIMAKSI - Sistem Informasi Manajemen Pendakian Gunung
                </p>
            </div>
        </div>
    </div>
</body>
</html>
