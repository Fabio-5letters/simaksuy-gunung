<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 h-screen flex items-center justify-center">
  <div class="bg-white p-8 rounded shadow-md w-96">
    <h1 class="text-2xl font-bold mb-4">Register</h1>
    <form action="/register" method="POST">
      <div class="mb-4">
        <label for="nama" class="block text-sm font-medium">Nama</label>
        <input type="text" id="nama" name="nama" class="w-full border rounded px-3 py-2" required>
      </div>
      <div class="mb-4">
        <label for="email" class="block text-sm font-medium">Email</label>
        <input type="email" id="email" name="email" class="w-full border rounded px-3 py-2" required>
      </div>
      <div class="mb-4">
        <label for="password" class="block text-sm font-medium">Password</label>
        <input type="password" id="password" name="password" class="w-full border rounded px-3 py-2" required>
      </div>
      <button type="submit" class="w-full bg-blue-500 text-white py-2 rounded">Register</button>
    </form>
    <p class="text-sm mt-4">Sudah punya akun? <a href="/login" class="text-blue-500">Login</a></p>
  </div>
</body>
</html>