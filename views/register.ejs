<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daftar - SIMAKSI Pendakian</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');
    
    :root {
      --forest-green: #1a3c34;
      --sunset-orange: #ff8c42;
      --deep-orange: #e67e22;
      --glass-bg: rgba(255, 255, 255, 0.15);
      --glass-border: rgba(255, 255, 255, 0.2);
    }

    * {
      font-family: 'Plus Jakarta Sans', sans-serif;
    }

    body {
      background: url('https://images.unsplash.com/photo-1454496522488-7a8e488e8606?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80') center center no-repeat;
      background-size: cover;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow-x: hidden;
      padding: 20px;
    }

    /* Dark Overlay & Topography Pattern */
    body::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at center, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.7) 100%);
      z-index: 1;
    }

    .topo-pattern {
      position: absolute;
      inset: 0;
      opacity: 0.1;
      background-image: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M10 10 Q 30 10 50 40 T 90 70 M0 30 Q 20 20 40 50 T 80 80 M20 0 Q 40 10 60 40 T 100 70' fill='none' stroke='%23ffffff' stroke-width='0.5'/%3E%3C/svg%3E");
      z-index: 2;
      pointer-events: none;
    }

    .register-container {
      position: relative;
      z-index: 10;
      background: var(--glass-bg);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--glass-border);
      border-radius: 24px;
      width: 100%;
      max-width: 450px;
      padding: 40px;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
      animation: fadeIn 0.8s ease-out;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .logo-container {
      width: 70px;
      height: 70px;
      background: var(--glass-bg);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
      transform: rotate(5deg);
      transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .register-container:hover .logo-container {
      transform: rotate(0deg) scale(1.1);
      background: var(--sunset-orange);
      border-color: var(--sunset-orange);
    }

    .logo-container i {
      color: white;
      font-size: 32px;
    }

    h1 {
      color: white;
      font-size: 30px;
      font-weight: 800;
      text-align: center;
      letter-spacing: -0.025em;
      margin-bottom: 6px;
    }

    .subtitle {
      color: rgba(255, 255, 255, 0.7);
      text-align: center;
      font-size: 14px;
      margin-bottom: 28px;
    }

    .input-group {
      margin-bottom: 18px;
    }

    .input-group label {
      display: block;
      color: rgba(255, 255, 255, 0.9);
      font-size: 13px;
      font-weight: 600;
      margin-bottom: 6px;
      margin-left: 4px;
    }

    .input-wrapper {
      position: relative;
      transition: all 0.3s ease;
    }

    .input-wrapper i {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: rgba(255, 255, 255, 0.5);
      transition: all 0.3s ease;
    }

    .input-wrapper input {
      width: 100%;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid var(--glass-border);
      border-radius: 12px;
      padding: 11px 16px 11px 48px;
      color: white;
      font-size: 14px;
      transition: all 0.3s ease;
      outline: none;
    }

    .input-wrapper input:focus {
      background: rgba(255, 255, 255, 0.2);
      border-color: var(--sunset-orange);
      box-shadow: 0 0 0 4px rgba(255, 140, 66, 0.2);
    }

    .input-wrapper input:focus + i {
      color: var(--sunset-orange);
    }

    .btn-primary {
      width: 100%;
      background: linear-gradient(135deg, var(--sunset-orange) 0%, var(--deep-orange) 100%);
      color: white;
      font-weight: 700;
      padding: 13px;
      border-radius: 12px;
      margin-top: 10px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      box-shadow: 0 10px 20px -10px rgba(255, 140, 66, 0.5);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 15px 25px -10px rgba(255, 140, 66, 0.6);
      filter: brightness(1.1);
    }

    .alert-error {
      background: rgba(239, 68, 68, 0.2);
      border: 1px solid rgba(239, 68, 68, 0.3);
      padding: 10px;
      border-radius: 12px;
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 10px;
      color: #fecaca;
      font-size: 13px;
    }

    .footer-links {
      margin-top: 28px;
      text-align: center;
      color: rgba(255, 255, 255, 0.6);
      font-size: 13px;
    }

    .footer-links a {
      color: white;
      font-weight: 700;
      transition: all 0.3s ease;
    }

    .footer-links a:hover {
      color: var(--sunset-orange);
      text-decoration: underline;
    }

    .password-toggle {
      position: absolute;
      right: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: rgba(255, 255, 255, 0.5);
      cursor: pointer;
      z-index: 10;
    }

    .password-strength {
      margin-top: 8px;
      height: 4px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 2px;
      overflow: hidden;
    }

    .password-strength-bar {
      height: 100%;
      width: 0%;
      background: #ef4444;
      transition: all 0.3s ease;
    }
    
    .strength-weak { width: 33%; background: #ef4444; }
    .strength-medium { width: 66%; background: #f59e0b; }
    .strength-strong { width: 100%; background: #22c55e; }
  </style>
</head>
<body>
  <div class="topo-pattern"></div>
  
  <div class="register-container">
    <div class="logo-container">
      <i class="fas fa-mountain-sun"></i>
    </div>
    
    <h1>Gabung Ekspedisi</h1>
    <p class="subtitle">Mulai langkah pertama petualangan Anda</p>

    <% if (error) { %>
      <div class="alert-error">
        <i class="fas fa-circle-exclamation"></i>
        <span><%= error %></span>
      </div>
    <% } %>

    <form action="/register" method="POST" id="registerForm">
      <div class="input-group">
        <label for="nama">Identitas Pendaki</label>
        <div class="input-wrapper">
          <i class="fas fa-user-tag"></i>
          <input type="text" id="nama" name="nama" placeholder="Nama Lengkap Anda" required>
        </div>
      </div>

      <div class="input-group">
        <label for="email">E-mail Kontak</label>
        <div class="input-wrapper">
          <i class="fas fa-envelope"></i>
          <input type="email" id="email" name="email" placeholder="pendaki@rimba.com" required>
        </div>
      </div>

      <div class="input-group">
        <label for="password">Kunci Keamanan</label>
        <div class="input-wrapper">
          <i class="fas fa-vault"></i>
          <input type="password" id="password" name="password" placeholder="Minimal 8 karakter" required onkeyup="checkPasswordStrength()">
          <span class="password-toggle" onclick="togglePassword()">
            <i class="fas fa-eye" id="toggleIcon"></i>
          </span>
        </div>
        <div class="password-strength">
          <div class="password-strength-bar" id="strengthBar"></div>
        </div>
      </div>

      <button type="submit" class="btn-primary">
        <span>DAFTAR SEKARANG</span>
        <i class="fas fa-compass"></i>
      </button>
    </form>

    <div class="footer-links">
      Sudah terdaftar di tim? <a href="/login">Masuk Kembali</a>
    </div>
  </div>

  <script>
    function togglePassword() {
      const input = document.getElementById('password');
      const icon = document.getElementById('toggleIcon');
      if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('fa-eye', 'fa-eye-slash');
      } else {
        input.type = 'password';
        icon.classList.replace('fa-eye-slash', 'fa-eye');
      }
    }

    function checkPasswordStrength() {
      const password = document.getElementById('password').value;
      const bar = document.getElementById('strengthBar');
      
      bar.classList.remove('strength-weak', 'strength-medium', 'strength-strong');
      
      if (password.length === 0) return;
      
      if (password.length < 6) {
        bar.classList.add('strength-weak');
      } else if (password.length < 10) {
        bar.classList.add('strength-medium');
      } else {
        bar.classList.add('strength-strong');
      }
    }
  </script>
</body>
</html>