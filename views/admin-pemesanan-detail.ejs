<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Detail Pemesanan - Admin SIMAKSI</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    * { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .sidebar { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .sidebar-item:hover { background: rgba(255, 255, 255, 0.2); }
    .sidebar-item.active { background: rgba(255, 255, 255, 0.3); border-left: 4px solid #fff; }
    .card-shadow { box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); transition: all 0.3s ease; }
    .card-shadow:hover { box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15); transform: translateY(-2px); }
    .btn-verify { background: linear-gradient(135deg, #10b981 0%, #059669 100%); transition: all 0.3s ease; }
    .btn-verify:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(16, 185, 129, 0.3); }
    .btn-reject { background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); transition: all 0.3s ease; }
    .btn-reject:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(239, 68, 68, 0.3); }
  </style>
</head>
<body class="bg-gray-100">
  <div class="flex h-screen">
    <!-- Sidebar -->
    <aside class="sidebar w-64 text-white p-6 overflow-y-auto">
      <div class="mb-8">
        <div class="flex items-center space-x-3 mb-1">
          <i class="fas fa-mountain text-2xl"></i>
          <h1 class="text-2xl font-bold">SIMAKSI</h1>
        </div>
        <p class="text-purple-200 text-sm">Admin Panel</p>
      </div>

      <nav class="space-y-2">
        <a href="/admin" class="sidebar-item block px-4 py-3 rounded-lg transition">
          <i class="fas fa-chart-line mr-3"></i>Dashboard
        </a>
        <a href="/admin#gunung" class="sidebar-item block px-4 py-3 rounded-lg transition">
          <i class="fas fa-mountain mr-3"></i>Kelola Gunung
        </a>
        <a href="/admin#berita" class="sidebar-item block px-4 py-3 rounded-lg transition">
          <i class="fas fa-newspaper mr-3"></i>Kelola Berita
        </a>
        <a href="/admin#simaksi" class="sidebar-item block px-4 py-3 rounded-lg transition">
          <i class="fas fa-person-hiking mr-3"></i>Kelola Simaksi
        </a>
        <hr class="my-4 border-purple-400">
        <a href="/admin/pemesanan" class="sidebar-item active block px-4 py-3 rounded-lg transition">
          <i class="fas fa-money-check-alt mr-3"></i>Kelola Pemesanan
        </a>
        <hr class="my-4 border-purple-400">
        <a href="/logout" class="sidebar-item block px-4 py-3 rounded-lg transition">
          <i class="fas fa-sign-out-alt mr-3"></i>Logout
        </a>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-auto">
      <!-- Top Bar -->
      <header class="bg-white shadow-sm p-6 border-b border-gray-100">
        <div class="flex justify-between items-center">
          <div>
            <h2 class="text-2xl font-bold text-gray-800">Detail Pemesanan</h2>
            <p class="text-sm text-gray-500 mt-1">Verifikasi pembayaran pendaki</p>
          </div>
          <a href="/admin/pemesanan" class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg font-semibold hover:bg-gray-300 transition">
            <i class="fas fa-arrow-left mr-2"></i>Kembali
          </a>
        </div>
      </header>

      <!-- Flash Messages -->
      <% if (locals.success && success.length > 0) { %>
        <div class="mx-6 mt-6 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg flex items-center">
          <i class="fas fa-check-circle mr-2"></i>
          <span><%= success[0] %></span>
        </div>
      <% } %>
      <% if (locals.error && error.length > 0) { %>
        <div class="mx-6 mt-6 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg flex items-center">
          <i class="fas fa-exclamation-circle mr-2"></i>
          <span><%= error[0] %></span>
        </div>
      <% } %>

      <!-- Content -->
      <div class="p-6 max-w-5xl mx-auto">
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
          <!-- Status Header -->
          <div class="p-8 text-center
            <% if (pemesanan.status === 'diverifikasi') { %>
              bg-gradient-to-r from-green-500 to-emerald-600 text-white
            <% } else if (pemesanan.status === 'ditolak') { %>
              bg-gradient-to-r from-red-500 to-rose-600 text-white
            <% } else if (pemesanan.status === 'dibayar') { %>
              bg-gradient-to-r from-yellow-500 to-amber-600 text-white
            <% } else { %>
              bg-gradient-to-r from-gray-400 to-gray-500 text-white
            <% } %>
          ">
            <div class="w-20 h-20 bg-white bg-opacity-20 rounded-full flex items-center justify-center mx-auto mb-4">
              <% if (pemesanan.status === 'diverifikasi') { %>
                <i class="fas fa-check-circle text-4xl"></i>
              <% } else if (pemesanan.status === 'ditolak') { %>
                <i class="fas fa-times-circle text-4xl"></i>
              <% } else if (pemesanan.status === 'dibayar') { %>
                <i class="fas fa-hourglass-half text-4xl"></i>
              <% } else { %>
                <i class="fas fa-clock text-4xl"></i>
              <% } %>
            </div>
            <h2 class="text-3xl font-black mb-2">
              <% if (pemesanan.status === 'diverifikasi') { %>
                DIVERIFIKASI
              <% } else if (pemesanan.status === 'ditolak') { %>
                DITOLAK
              <% } else if (pemesanan.status === 'dibayar') { %>
                MENUNGGU VERIFIKASI
              <% } else { %>
                PENDING
              <% } %>
            </h2>
            <p class="text-white text-opacity-90">
              <% if (pemesanan.status === 'dibayar') { %>
                Bukti pembayaran telah diupload, menunggu verifikasi admin
              <% } else if (pemesanan.status === 'pending') { %>
                Belum ada bukti pembayaran yang diupload
              <% } %>
            </p>
          </div>

          <div class="p-8">
            <!-- Grid Layout -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
              <!-- Left Column: Booking Info -->
              <div>
                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                  <i class="fas fa-user mr-2 text-purple-600"></i>Data Pendaki
                </h3>
                <div class="bg-gray-50 rounded-xl p-5 mb-6 border border-gray-200">
                  <div class="space-y-3">
                    <div>
                      <p class="text-xs text-gray-500">Nama Lengkap</p>
                      <p class="font-semibold text-gray-900"><%= pemesanan.nama_user %></p>
                    </div>
                    <div class="border-t border-gray-200"></div>
                    <div>
                      <p class="text-xs text-gray-500">Email</p>
                      <p class="font-semibold text-gray-900"><%= pemesanan.email_user %></p>
                    </div>
                    <div class="border-t border-gray-200"></div>
                    <div>
                      <p class="text-xs text-gray-500">Nomor HP</p>
                      <p class="font-semibold text-gray-900"><%= pemesanan.nomor_hp %></p>
                    </div>
                  </div>
                </div>

                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                  <i class="fas fa-mountain mr-2 text-purple-600"></i>Data Pendakian
                </h3>
                <div class="bg-gray-50 rounded-xl p-5 border border-gray-200">
                  <div class="space-y-3">
                    <div>
                      <p class="text-xs text-gray-500">Kode Booking</p>
                      <p class="font-mono font-bold text-purple-600"><%= pemesanan.kode_booking %></p>
                    </div>
                    <div class="border-t border-gray-200"></div>
                    <div>
                      <p class="text-xs text-gray-500">Tujuan</p>
                      <p class="font-semibold text-gray-900"><%= pemesanan.nama_gunung %> (<%= pemesanan.ketinggian %> mdpl)</p>
                      <p class="text-sm text-gray-500"><%= pemesanan.lokasi %></p>
                    </div>
                    <div class="border-t border-gray-200"></div>
                    <div class="grid grid-cols-2 gap-4">
                      <div>
                        <p class="text-xs text-gray-500">Tanggal Masuk</p>
                        <p class="font-semibold text-gray-900"><%= new Date(pemesanan.tanggal_masuk).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
                      </div>
                      <div>
                        <p class="text-xs text-gray-500">Tanggal Keluar</p>
                        <p class="font-semibold text-gray-900"><%= new Date(pemesanan.tanggal_keluar).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></p>
                      </div>
                    </div>
                    <div class="border-t border-gray-200"></div>
                    <div class="grid grid-cols-2 gap-4">
                      <div>
                        <p class="text-xs text-gray-500">Pintu Masuk</p>
                        <p class="font-semibold text-gray-900"><%= pemesanan.pintu_masuk %></p>
                      </div>
                      <div>
                        <p class="text-xs text-gray-500">Pintu Keluar</p>
                        <p class="font-semibold text-gray-900"><%= pemesanan.pintu_keluar %></p>
                      </div>
                    </div>
                    <div class="border-t border-gray-200"></div>
                    <div class="grid grid-cols-2 gap-4">
                      <div>
                        <p class="text-xs text-gray-500">Jumlah Anggota</p>
                        <p class="font-semibold text-gray-900"><%= pemesanan.jumlah_anggota %> orang</p>
                      </div>
                      <div>
                        <p class="text-xs text-gray-500">Harga per Orang</p>
                        <p class="font-semibold text-gray-900"><%= formatRupiah(pemesanan.harga_per_orang) %></p>
                      </div>
                    </div>
                    <div class="border-t border-gray-200"></div>
                    <div>
                      <p class="text-xs text-gray-500">Total Bayar</p>
                      <p class="font-bold text-2xl text-green-600"><%= formatRupiah(pemesanan.total_bayar) %></p>
                    </div>
                    <div class="border-t border-gray-200"></div>
                    <div>
                      <p class="text-xs text-gray-500">Metode Pembayaran</p>
                      <p class="font-semibold text-gray-900"><%= pemesanan.metode_pembayaran %></p>
                    </div>
                    <% if (pemesanan.catatan) { %>
                      <div class="border-t border-gray-200"></div>
                      <div>
                        <p class="text-xs text-gray-500">Catatan dari Pendaki</p>
                        <p class="text-gray-700 italic"><%= pemesanan.catatan %></p>
                      </div>
                    <% } %>
                  </div>
                </div>
              </div>

              <!-- Right Column: Payment Proof -->
              <div>
                <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                  <i class="fas fa-image mr-2 text-purple-600"></i>Bukti Pembayaran
                </h3>

                <% if (pemesanan.bukti_pembayaran) { %>
                  <div class="bg-gray-50 rounded-xl p-5 border border-gray-200 mb-6">
                    <div class="mb-4">
                      <p class="text-xs text-gray-500 mb-2">File Bukti</p>
                      <p class="text-sm font-mono bg-gray-100 px-3 py-2 rounded"><%= pemesanan.bukti_pembayaran %></p>
                    </div>

                    <!-- Image Preview -->
                    <div class="mb-4">
                      <img src="/uploads/bukti-pembayaran/<%= pemesanan.bukti_pembayaran %>"
                           alt="Bukti Pembayaran"
                           class="w-full rounded-lg shadow-md border border-gray-200">
                    </div>

                    <% if (pemesanan.catatan) { %>
                      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                        <p class="text-xs text-blue-600 font-semibold mb-1">Catatan dari Pendaki:</p>
                        <p class="text-sm text-blue-800"><%= pemesanan.catatan %></p>
                      </div>
                    <% } %>
                  </div>
                <% } else { %>
                  <div class="bg-yellow-50 border-2 border-yellow-300 rounded-xl p-8 text-center mb-6">
                    <i class="fas fa-exclamation-triangle text-yellow-600 text-5xl mb-4"></i>
                    <h4 class="font-bold text-yellow-800 text-lg mb-2">Belum Ada Bukti Pembayaran</h4>
                    <p class="text-sm text-yellow-700">Pendaki belum mengupload bukti pembayaran.</p>
                  </div>
                <% } %>

                <!-- Admin Verification Form -->
                <% if (pemesanan.bukti_pembayaran && pemesanan.status === 'dibayar') { %>
                  <div class="bg-purple-50 border-2 border-purple-300 rounded-xl p-6">
                    <h4 class="font-bold text-purple-800 mb-4 flex items-center">
                      <i class="fas fa-shield-alt mr-2"></i>Verifikasi Pembayaran
                    </h4>

                    <form action="/admin/verifikasi/<%= pemesanan.id %>" method="POST">
                      <div class="mb-4">
                        <label for="catatan_admin" class="block text-sm font-semibold text-gray-700 mb-2">
                          Catatan Admin (Opsional)
                        </label>
                        <textarea id="catatan_admin" name="catatan_admin" rows="3"
                                  placeholder="Tambahkan catatan verifikasi..."
                                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent resize-none"></textarea>
                      </div>

                      <div class="flex gap-3">
                        <button type="submit" name="status" value="diverifikasi"
                                class="flex-1 btn-verify text-white font-bold py-3 px-6 rounded-xl flex items-center justify-center">
                          <i class="fas fa-check-circle mr-2"></i>
                          Verifikasi
                        </button>
                        <button type="submit" name="status" value="ditolak"
                                class="flex-1 btn-reject text-white font-bold py-3 px-6 rounded-xl flex items-center justify-center">
                          <i class="fas fa-times-circle mr-2"></i>
                          Tolak
                        </button>
                      </div>
                    </form>
                  </div>
                <% } else if (pemesanan.status === 'diverifikasi') { %>
                  <div class="bg-green-50 border-2 border-green-300 rounded-xl p-6 text-center">
                    <i class="fas fa-check-circle text-green-600 text-4xl mb-3"></i>
                    <h4 class="font-bold text-green-800 text-lg mb-2">Pembayaran Terverifikasi</h4>
                    <% if (pemesanan.catatan_admin) { %>
                      <p class="text-sm text-green-700 mb-2">Catatan Admin:</p>
                      <p class="text-sm text-green-800 bg-green-100 px-4 py-2 rounded"><%= pemesanan.catatan_admin %></p>
                    <% } %>
                  </div>
                <% } else if (pemesanan.status === 'ditolak') { %>
                  <div class="bg-red-50 border-2 border-red-300 rounded-xl p-6 text-center">
                    <i class="fas fa-times-circle text-red-600 text-4xl mb-3"></i>
                    <h4 class="font-bold text-red-800 text-lg mb-2">Pembayaran Ditolak</h4>
                    <% if (pemesanan.catatan_admin) { %>
                      <p class="text-sm text-red-700 mb-2">Catatan Admin:</p>
                      <p class="text-sm text-red-800 bg-red-100 px-4 py-2 rounded"><%= pemesanan.catatan_admin %></p>
                    <% } %>
                  </div>
                <% } else { %>
                  <div class="bg-gray-50 border-2 border-gray-300 rounded-xl p-6 text-center">
                    <i class="fas fa-info-circle text-gray-600 text-4xl mb-3"></i>
                    <h4 class="font-bold text-gray-800 text-lg mb-2">Menunggu Bukti Pembayaran</h4>
                    <p class="text-sm text-gray-600">Pendaki belum mengupload bukti pembayaran.</p>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>
