<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Detail Pemesanan - Admin SIMAKSI</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');
    * { font-family: 'Plus Jakarta Sans', sans-serif; }
    .sidebar { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .sidebar-item:hover { background: rgba(255, 255, 255, 0.2); }
    .sidebar-item.active { background: rgba(255, 255, 255, 0.2); border-left: 4px solid white; }
    .card-glass { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); }
  </style>
</head>
<body class="bg-gray-50 min-h-screen">
  <div class="flex">
    <!-- Sidebar -->
    <aside class="sidebar w-64 min-h-screen text-white p-6 sticky top-0 h-screen overflow-y-auto">
        <div class="mb-10">
            <div class="flex items-center space-x-3 mb-1">
                <i class="fas fa-mountain-sun text-3xl"></i>
                <h1 class="text-2xl font-bold tracking-tight">SIMAKSI</h1>
            </div>
            <p class="text-purple-200 text-xs uppercase tracking-widest font-semibold">Admin Panel</p>
        </div>

        <nav class="space-y-2">
            <a href="/admin" class="sidebar-item block px-4 py-3 rounded-xl transition">
                <i class="fas fa-chart-pie mr-3"></i>Dashboard
            </a>
            <a href="/admin/pemesanan" class="sidebar-item active block px-4 py-3 rounded-xl transition">
                <i class="fas fa-shopping-cart mr-3"></i>Data Pemesanan
            </a>
            <div class="pt-4 pb-2">
                <p class="px-4 text-[10px] font-bold text-purple-200 uppercase tracking-widest">Manajemen</p>
            </div>
            <a href="/admin/gunung" class="sidebar-item block px-4 py-3 rounded-xl transition">
                <i class="fas fa-mountain mr-3"></i>Kelola Gunung
            </a>
            <a href="/admin/berita" class="sidebar-item block px-4 py-3 rounded-xl transition">
                <i class="fas fa-newspaper mr-3"></i>Kelola Berita
            </a>
            <a href="/admin/pendakian" class="sidebar-item block px-4 py-3 rounded-xl transition">
                <i class="fas fa-calendar-alt mr-3"></i>Kelola Pendakian
            </a>
            <hr class="my-6 border-purple-400 opacity-30">
            <a href="/logout" class="sidebar-item block px-4 py-3 rounded-xl hover:bg-red-500 transition text-red-100">
                <i class="fas fa-sign-out-alt mr-3"></i>Keluar
            </a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-8">
      <div class="mb-8 flex items-center justify-between">
        <div>
            <a href="/admin/pemesanan" class="text-purple-600 font-bold text-sm flex items-center mb-2 hover:text-purple-700 transition">
                <i class="fas fa-arrow-left mr-2"></i>Kembali ke Daftar
            </a>
            <h2 class="text-3xl font-black text-gray-800 tracking-tight">Detail Pemesanan</h2>
        </div>
        <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 flex items-center">
            <span class="text-xs font-black text-gray-400 uppercase tracking-widest mr-3">Status Saat Ini:</span>
            <% if (order.status === 'pending') { %>
                <span class="bg-gray-100 text-gray-600 px-4 py-1.5 rounded-full text-[10px] font-black uppercase">Pending</span>
            <% } else if (order.status === 'dibayar') { %>
                <span class="bg-yellow-100 text-yellow-600 px-4 py-1.5 rounded-full text-[10px] font-black uppercase border border-yellow-200">Menunggu Verifikasi</span>
            <% } else if (order.status === 'diverifikasi') { %>
                <span class="bg-green-100 text-green-600 px-4 py-1.5 rounded-full text-[10px] font-black uppercase border border-green-200">Diverifikasi</span>
            <% } else { %>
                <span class="bg-red-100 text-red-600 px-4 py-1.5 rounded-full text-[10px] font-black uppercase border border-red-200">Ditolak</span>
            <% } %>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Informasi Pendaki & Gunung -->
        <div class="lg:col-span-2 space-y-8">
          <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
            <div class="p-8 border-b border-gray-50 bg-gray-50/50 flex justify-between items-center">
                <h3 class="text-lg font-black text-gray-800 uppercase tracking-tight flex items-center">
                    <i class="fas fa-info-circle mr-3 text-purple-600"></i>Informasi Perjalanan
                </h3>
                <span class="font-mono font-bold text-purple-600 bg-purple-50 px-4 py-1 rounded-xl border border-purple-100"><%= order.kode_booking %></span>
            </div>
            <div class="p-8">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-6">
                  <div>
                    <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">Gunung Tujuan</p>
                    <div class="flex items-center">
                        <div class="w-12 h-12 bg-purple-100 text-purple-600 rounded-xl flex items-center justify-center mr-4 text-xl">
                            <i class="fas fa-mountain"></i>
                        </div>
                        <div>
                            <p class="text-xl font-black text-gray-800"><%= order.nama_gunung %></p>
                            <p class="text-xs text-gray-400 font-bold uppercase"><%= order.pintu_masuk %> — <%= order.pintu_keluar %></p>
                        </div>
                    </div>
                  </div>
                  <div>
                    <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">Jadwal Pendakian</p>
                    <div class="bg-gray-50 p-4 rounded-2xl border border-gray-100 flex items-center justify-between">
                        <div class="text-center flex-1">
                            <p class="text-[10px] font-black text-purple-600 uppercase">Naik</p>
                            <p class="font-black text-gray-800"><%= new Date(order.tanggal_masuk).toLocaleDateString('id-ID', {day:'numeric', month:'short', year:'numeric'}) %></p>
                        </div>
                        <div class="px-4 text-gray-300">
                            <i class="fas fa-chevron-right"></i>
                        </div>
                        <div class="text-center flex-1">
                            <p class="text-[10px] font-black text-orange-600 uppercase">Turun</p>
                            <p class="font-black text-gray-800"><%= new Date(order.tanggal_keluar).toLocaleDateString('id-ID', {day:'numeric', month:'short', year:'numeric'}) %></p>
                        </div>
                    </div>
                  </div>
                </div>
                <div class="space-y-6">
                    <div>
                        <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">Data Pemesan</p>
                        <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                            <p class="font-black text-gray-800 text-lg"><%= order.nama_user || 'Pendaki' %></p>
                            <p class="text-sm text-gray-500 flex items-center mt-1">
                                <i class="fas fa-envelope mr-2 text-purple-400"></i><%= order.email %>
                            </p>
                            <p class="text-sm text-gray-500 flex items-center mt-1">
                                <i class="fas fa-phone mr-2 text-green-400"></i><%= order.nomor_hp %>
                            </p>
                        </div>
                    </div>
                    <div class="flex items-center justify-between bg-purple-600 p-4 rounded-2xl text-white shadow-lg shadow-purple-100">
                        <div>
                            <p class="text-[10px] font-black uppercase opacity-80 tracking-widest">Jumlah Anggota</p>
                            <p class="text-2xl font-black"><%= order.jumlah_anggota %> Orang</p>
                        </div>
                        <i class="fas fa-users text-3xl opacity-30"></i>
                    </div>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden">
            <div class="p-8 border-b border-gray-50 bg-gray-50/50">
                <h3 class="text-lg font-black text-gray-800 uppercase tracking-tight flex items-center">
                    <i class="fas fa-camera mr-3 text-purple-600"></i>Bukti Pembayaran
                </h3>
            </div>
            <div class="p-8 flex flex-col items-center justify-center">
              <% if (order.bukti_pembayaran) { %>
                <div class="relative group cursor-zoom-in">
                    <img src="/uploads/bukti-pembayaran/<%= order.bukti_pembayaran %>" alt="Bukti Pembayaran" class="max-w-full h-auto rounded-2xl shadow-2xl border-4 border-white transition group-hover:scale-[1.01]">
                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition flex items-center justify-center rounded-2xl">
                        <a href="/uploads/bukti-pembayaran/<%= order.bukti_pembayaran %>" target="_blank" class="bg-white text-gray-800 font-black py-3 px-8 rounded-2xl shadow-xl">
                            <i class="fas fa-expand mr-2"></i>Lihat Ukuran Penuh
                        </a>
                    </div>
                </div>
              <% } else { %>
                <div class="py-20 text-center">
                    <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4 text-gray-300 text-3xl">
                        <i class="fas fa-image-slash"></i>
                    </div>
                    <p class="text-gray-400 font-bold uppercase tracking-widest">Belum ada bukti pembayaran yang diunggah</p>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <!-- Panel Verifikasi -->
        <div class="space-y-8">
          <div class="bg-white rounded-3xl shadow-xl border border-gray-100 overflow-hidden sticky top-24">
            <div class="p-8 border-b border-gray-50 bg-purple-600 text-white">
                <h3 class="text-lg font-black uppercase tracking-tight">Panel Verifikasi</h3>
                <p class="text-[10px] font-bold uppercase opacity-80">Tinjau dan ambil keputusan</p>
            </div>
            <div class="p-8">
              <div class="mb-8">
                <p class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">Total yang Harus Dibayar</p>
                <p class="text-4xl font-black text-gray-800">Rp <%= order.total_bayar.toLocaleString('id-ID') %></p>
                <p class="text-[10px] font-bold text-purple-600 mt-1 italic">Metode: <%= order.metode_pembayaran %></p>
              </div>

              <form action="/admin/verifikasi/<%= order.id %>" method="POST" class="space-y-6">
                <div>
                  <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 block">Keputusan Admin</label>
                  <select name="status" class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl p-4 font-bold text-gray-700 focus:border-purple-500 focus:outline-none transition appearance-none cursor-pointer" required>
                    <option value="diverifikasi" <%= order.status === 'diverifikasi' ? 'selected' : '' %>>Sahkan / Terima</option>
                    <option value="ditolak" <%= order.status === 'ditolak' ? 'selected' : '' %>>Tolak Pembayaran</option>
                  </select>
                </div>
                <div>
                  <label class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2 block">Catatan untuk Pendaki</label>
                  <textarea name="catatan_admin" rows="4" class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl p-4 font-medium text-gray-700 focus:border-purple-500 focus:outline-none transition resize-none" placeholder="Alasan penolakan atau instruksi tambahan..."><%= order.catatan_admin %></textarea>
                </div>
                <button type="submit" class="w-full bg-purple-600 text-white font-black py-5 rounded-2xl shadow-xl shadow-purple-100 hover:bg-purple-700 transition transform hover:-translate-y-1 active:translate-y-0">
                  SIMPAN KEPUTUSAN
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>