<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Riwayat Pemesanan - SIMAKSI Gunung</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
      * { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
      .gradient-header { background: linear-gradient(135deg, #1e5631 0%, #2d7a3e 50%, #3a9f5d 100%); }
      .btn-primary { background: linear-gradient(135deg, #1e5631 0%, #3a9f5d 100%); transition: all 0.3s ease; }
      .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(30, 86, 49, 0.3); }
    </style>
</head>
<body class="bg-gradient-to-br from-gray-50 to-gray-100 min-h-screen">

    <!-- Navbar -->
    <header class="gradient-header text-white shadow-xl sticky top-0 z-50">
        <div class="container mx-auto flex justify-between items-center py-4 px-6">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center">
                    <i class="fas fa-mountain text-green-700 text-lg"></i>
                </div>
                <h1 class="text-2xl font-bold">SIMAKSI Gunung</h1>
            </div>
            <nav class="hidden md:flex space-x-6">
                <a href="/beranda" class="hover:text-green-200 transition"><i class="fas fa-home mr-1"></i>Beranda</a>
                <a href="/pendakian" class="hover:text-green-200 transition"><i class="fas fa-hiking mr-1"></i>Pendakian</a>
            </nav>
            <% if (user) { %>
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center">
                        <i class="fas fa-user text-green-700"></i>
                    </div>
                    <span class="font-semibold"><%= user.nama %></span>
                </div>
            <% } %>
        </div>
    </header>

    <!-- Main Content -->
    <div class="container mx-auto px-6 py-10 max-w-5xl">
        <!-- Page Header -->
        <div class="mb-8">
            <h2 class="text-3xl font-black text-gray-900 mb-2">
                <i class="fas fa-history text-green-600 mr-3"></i>Riwayat Pemesanan
            </h2>
            <p class="text-gray-600">Daftar semua pemesanan pendakian Anda</p>
        </div>

        <!-- Statistics -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <div class="bg-white rounded-xl p-4 shadow-sm border border-gray-200">
                <p class="text-xs text-gray-500">Total Pemesanan</p>
                <p class="text-2xl font-bold text-gray-900"><%= pemesanan.length %></p>
            </div>
            <div class="bg-yellow-50 rounded-xl p-4 shadow-sm border border-yellow-200">
                <p class="text-xs text-yellow-700">Menunggu</p>
                <p class="text-2xl font-bold text-yellow-700">
                    <%= pemesanan.filter(p => p.status === 'pending' || p.status === 'dibayar').length %>
                </p>
            </div>
            <div class="bg-green-50 rounded-xl p-4 shadow-sm border border-green-200">
                <p class="text-xs text-green-700">Diverifikasi</p>
                <p class="text-2xl font-bold text-green-700">
                    <%= pemesanan.filter(p => p.status === 'diverifikasi').length %>
                </p>
            </div>
            <div class="bg-red-50 rounded-xl p-4 shadow-sm border border-red-200">
                <p class="text-xs text-red-700">Ditolak</p>
                <p class="text-2xl font-bold text-red-700">
                    <%= pemesanan.filter(p => p.status === 'ditolak').length %>
                </p>
            </div>
        </div>

        <!-- Orders List -->
        <% if (pemesanan && pemesanan.length > 0) { %>
            <div class="space-y-4">
                <% pemesanan.forEach(order => { %>
                    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition">
                        <div class="p-6">
                            <div class="flex flex-col md:flex-row md:items-center md:justify-between">
                                <div class="flex-1">
                                    <div class="flex items-center justify-between mb-3">
                                        <div>
                                            <h3 class="text-lg font-bold text-gray-900"><%= order.nama_gunung %></h3>
                                            <p class="text-sm text-gray-500 font-mono"><%= order.kode_booking %></p>
                                        </div>
                                        <% if (order.status === 'diverifikasi') { %>
                                            <span class="px-3 py-1 text-xs font-bold rounded-full bg-green-100 text-green-800">
                                                <i class="fas fa-check-circle mr-1"></i>Diverifikasi
                                            </span>
                                        <% } else if (order.status === 'ditolak') { %>
                                            <span class="px-3 py-1 text-xs font-bold rounded-full bg-red-100 text-red-800">
                                                <i class="fas fa-times-circle mr-1"></i>Ditolak
                                            </span>
                                        <% } else if (order.status === 'dibayar') { %>
                                            <span class="px-3 py-1 text-xs font-bold rounded-full bg-yellow-100 text-yellow-800">
                                                <i class="fas fa-hourglass-half mr-1"></i>Menunggu Verifikasi
                                            </span>
                                        <% } else { %>
                                            <span class="px-3 py-1 text-xs font-bold rounded-full bg-gray-100 text-gray-800">
                                                <i class="fas fa-clock mr-1"></i>Pending
                                            </span>
                                        <% } %>
                                    </div>
                                    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
                                        <div>
                                            <p class="text-xs text-gray-500">Tanggal</p>
                                            <p class="font-semibold"><%= new Date(order.tanggal_masuk).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %></p>
                                        </div>
                                        <div>
                                            <p class="text-xs text-gray-500">Durasi</p>
                                            <p class="font-semibold">
                                                <%= Math.ceil((new Date(order.tanggal_keluar) - new Date(order.tanggal_masuk)) / (1000 * 60 * 60 * 24)) %> hari
                                            </p>
                                        </div>
                                        <div>
                                            <p class="text-xs text-gray-500">Anggota</p>
                                            <p class="font-semibold"><%= order.jumlah_anggota %> orang</p>
                                        </div>
                                        <div>
                                            <p class="text-xs text-gray-500">Total</p>
                                            <p class="font-bold text-green-700"><%= formatRupiah(order.total_bayar) %></p>
                                        </div>
                                    </div>
                                </div>
                                <div class="mt-4 md:mt-0 md:ml-4">
                                    <a href="/status-pemesanan/<%= order.kode_booking %>" class="btn-primary text-white font-semibold py-2 px-4 rounded-lg inline-flex items-center">
                                        <i class="fas fa-eye mr-2"></i>Detail
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-16 text-center">
                <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i class="fas fa-inbox text-gray-400 text-4xl"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Belum Ada Pemesanan</h3>
                <p class="text-gray-500 mb-6">Anda belum membuat pemesanan pendakian apapun.</p>
                <a href="/pendakian" class="btn-primary text-white font-bold py-3 px-8 rounded-lg inline-block">
                    <i class="fas fa-hiking mr-2"></i>Mulai Pemesanan
                </a>
            </div>
        <% } %>
    </div>

    <!-- Footer -->
    <footer class="gradient-header text-white py-8 mt-12">
        <div class="container mx-auto px-6 text-center text-green-100 text-sm">
            <p>&copy; 2026 SIMAKSI - Sistem Informasi Manajemen Pendakian Gunung</p>
        </div>
    </footer>
</body>
</html>
