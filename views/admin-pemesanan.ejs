<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kelola Pemesanan - Admin SIMAKSI</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');
        * { font-family: 'Plus Jakarta Sans', sans-serif; }
        .sidebar { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .sidebar-item:hover { background: rgba(255, 255, 255, 0.2); }
        .sidebar-item.active { background: rgba(255, 255, 255, 0.2); border-left: 4px solid white; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <div class="flex">
        <!-- Sidebar -->
        <aside class="sidebar w-64 min-h-screen text-white p-6 sticky top-0 h-screen overflow-y-auto">
            <div class="mb-10">
                <div class="flex items-center space-x-3 mb-1">
                    <i class="fas fa-mountain-sun text-3xl"></i>
                    <h1 class="text-2xl font-bold tracking-tight">SIMAKSI</h1>
                </div>
                <p class="text-purple-200 text-xs uppercase tracking-widest font-semibold">Admin Panel</p>
            </div>

            <nav class="space-y-2">
                <a href="/admin" class="sidebar-item block px-4 py-3 rounded-xl transition">
                    <i class="fas fa-chart-pie mr-3"></i>Dashboard
                </a>
                <a href="/admin/pemesanan" class="sidebar-item active block px-4 py-3 rounded-xl transition">
                    <i class="fas fa-shopping-cart mr-3"></i>Data Pemesanan
                </a>
                <div class="pt-4 pb-2">
                    <p class="px-4 text-[10px] font-bold text-purple-200 uppercase tracking-widest">Manajemen</p>
                </div>
                <a href="/admin/gunung" class="sidebar-item block px-4 py-3 rounded-xl transition">
                    <i class="fas fa-mountain mr-3"></i>Kelola Gunung
                </a>
                <a href="/admin/berita" class="sidebar-item block px-4 py-3 rounded-xl transition">
                    <i class="fas fa-newspaper mr-3"></i>Kelola Berita
                </a>
                <a href="/admin/pendakian" class="sidebar-item block px-4 py-3 rounded-xl transition">
                    <i class="fas fa-calendar-alt mr-3"></i>Kelola Pendakian
                </a>
                <hr class="my-6 border-purple-400 opacity-30">
                <a href="/logout" class="sidebar-item block px-4 py-3 rounded-xl hover:bg-red-500 transition text-red-100">
                    <i class="fas fa-sign-out-alt mr-3"></i>Keluar
                </a>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h2 class="text-3xl font-bold text-gray-800 tracking-tight">Kelola Pemesanan</h2>
                    <p class="text-gray-500 font-medium">Verifikasi dan manajemen pembayaran pendaki</p>
                </div>
                <div class="flex items-center space-x-4 bg-white p-2 rounded-2xl shadow-sm border border-gray-100">
                    <div class="text-right px-3">
                        <p class="text-[10px] font-bold text-purple-600 uppercase">Administrator</p>
                        <p class="text-sm font-semibold text-gray-700">Admin</p>
                    </div>
                    <img src="https://ui-avatars.com/api/?name=Admin&background=667eea&color=fff" class="w-10 h-10 rounded-xl">
                </div>
            </div>

            <% if (success && success.length > 0) { %>
                <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-6 rounded-r-xl shadow-sm animate-fade-in" role="alert">
                    <div class="flex items-center">
                        <i class="fas fa-check-circle mr-3"></i>
                        <p class="font-bold"><%= success %></p>
                    </div>
                </div>
            <% } %>

            <% if (error && error.length > 0) { %>
                <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-6 rounded-r-xl shadow-sm animate-fade-in" role="alert">
                    <div class="flex items-center">
                        <i class="fas fa-exclamation-circle mr-3"></i>
                        <p class="font-bold"><%= error %></p>
                    </div>
                </div>
            <% } %>

            <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
                <div class="p-8 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
                    <h3 class="text-xl font-bold text-gray-800 flex items-center">
                        <i class="fas fa-table mr-3 text-purple-600"></i>Daftar Pemesanan
                    </h3>
                    <div class="flex space-x-2">
                        <span class="bg-blue-100 text-blue-700 text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-widest">Total: <%= pemesanan.length %></span>
                    </div>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-50/50 text-gray-400 uppercase text-[10px] font-black tracking-widest border-b border-gray-100">
                                <th class="px-8 py-5">Kode Booking</th>
                                <th class="px-8 py-5">Pendaki</th>
                                <th class="px-8 py-5">Gunung</th>
                                <th class="px-8 py-5 text-center">Anggota</th>
                                <th class="px-8 py-5">Total Bayar</th>
                                <th class="px-8 py-5 text-center">Status</th>
                                <th class="px-8 py-5 text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50">
                            <% if (pemesanan && pemesanan.length > 0) { %>
                                <% pemesanan.forEach(order => { %>
                                    <tr class="hover:bg-gray-50/80 transition group">
                                        <td class="px-8 py-5">
                                            <span class="font-mono font-bold text-purple-600 bg-purple-50 px-3 py-1 rounded-lg border border-purple-100"><%= order.kode_booking %></span>
                                        </td>
                                        <td class="px-8 py-5">
                                            <p class="font-bold text-gray-800"><%= order.nama_user || 'Pendaki' %></p>
                                            <p class="text-xs text-gray-400"><%= order.email %></p>
                                        </td>
                                        <td class="px-8 py-5">
                                            <p class="font-bold text-gray-700"><%= order.nama_gunung %></p>
                                            <p class="text-[10px] text-gray-400 uppercase font-black"><%= new Date(order.tanggal_masuk).toLocaleDateString('id-ID', {day:'numeric', month:'short', year:'numeric'}) %></p>
                                        </td>
                                        <td class="px-8 py-5 text-center">
                                            <span class="font-bold text-gray-600 bg-gray-100 px-3 py-1 rounded-lg"><%= order.jumlah_anggota %></span>
                                        </td>
                                        <td class="px-8 py-5 font-black text-gray-800">
                                            Rp <%= order.total_bayar.toLocaleString('id-ID') %>
                                        </td>
                                        <td class="px-8 py-5 text-center">
                                            <% if (order.status === 'pending') { %>
                                                <span class="bg-gray-100 text-gray-500 text-[10px] font-black px-3 py-1.5 rounded-full uppercase tracking-tighter">Pending</span>
                                            <% } else if (order.status === 'dibayar') { %>
                                                <span class="bg-yellow-100 text-yellow-600 text-[10px] font-black px-3 py-1.5 rounded-full uppercase tracking-tighter shadow-sm shadow-yellow-100 border border-yellow-200 animate-pulse">Menunggu Verifikasi</span>
                                            <% } else if (order.status === 'diverifikasi') { %>
                                                <span class="bg-green-100 text-green-600 text-[10px] font-black px-3 py-1.5 rounded-full uppercase tracking-tighter border border-green-200">Diverifikasi</span>
                                            <% } else { %>
                                                <span class="bg-red-100 text-red-600 text-[10px] font-black px-3 py-1.5 rounded-full uppercase tracking-tighter border border-red-200">Ditolak</span>
                                            <% } %>
                                        </td>
                                        <td class="px-8 py-5">
                                            <div class="flex justify-center">
                                                <a href="/admin/pemesanan/<%= order.id %>" class="bg-purple-600 text-white font-bold py-2 px-6 rounded-xl text-xs hover:bg-purple-700 transition shadow-lg shadow-purple-100 flex items-center">
                                                    <i class="fas fa-search-plus mr-2"></i>Detail
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="px-8 py-20 text-center">
                                        <div class="flex flex-col items-center">
                                            <i class="fas fa-inbox text-5xl text-gray-200 mb-4"></i>
                                            <p class="text-gray-400 font-bold uppercase tracking-widest">Belum ada data pemesanan</p>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>
</body>
</html>