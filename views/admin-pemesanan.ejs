<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kelola Pemesanan - Admin SIMAKSI</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    * { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .sidebar { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .sidebar-item:hover { background: rgba(255, 255, 255, 0.2); }
    .sidebar-item.active { background: rgba(255, 255, 255, 0.3); border-left: 4px solid #fff; }
    .card-shadow { box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); transition: all 0.3s ease; }
    .card-shadow:hover { box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15); transform: translateY(-2px); }
    .table-custom { border-collapse: collapse; }
    .table-custom th { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 1rem; text-align: left; }
    .table-custom td { padding: 1rem; border-bottom: 1px solid #e5e7eb; }
    .table-custom tbody tr:hover { background: #f9fafb; }
    .badge { @apply px-3 py-1 rounded-full text-xs font-semibold; }
  </style>
</head>
<body class="bg-gray-100">
  <div class="flex h-screen">
    <!-- Sidebar -->
    <aside class="sidebar w-64 text-white p-6 overflow-y-auto">
      <div class="mb-8">
        <div class="flex items-center space-x-3 mb-1">
          <i class="fas fa-mountain text-2xl"></i>
          <h1 class="text-2xl font-bold">SIMAKSI</h1>
        </div>
        <p class="text-purple-200 text-sm">Admin Panel</p>
      </div>

      <nav class="space-y-2">
        <a href="/admin" class="sidebar-item block px-4 py-3 rounded-lg transition">
          <i class="fas fa-chart-line mr-3"></i>Dashboard
        </a>
        <a href="/admin#gunung" class="sidebar-item block px-4 py-3 rounded-lg transition">
          <i class="fas fa-mountain mr-3"></i>Kelola Gunung
        </a>
        <a href="/admin#berita" class="sidebar-item block px-4 py-3 rounded-lg transition">
          <i class="fas fa-newspaper mr-3"></i>Kelola Berita
        </a>
        <a href="/admin#simaksi" class="sidebar-item block px-4 py-3 rounded-lg transition">
          <i class="fas fa-person-hiking mr-3"></i>Kelola Simaksi
        </a>
        <hr class="my-4 border-purple-400">
        <a href="/admin/pemesanan" class="sidebar-item active block px-4 py-3 rounded-lg transition">
          <i class="fas fa-money-check-alt mr-3"></i>Kelola Pemesanan
        </a>
        <hr class="my-4 border-purple-400">
        <a href="/logout" class="sidebar-item block px-4 py-3 rounded-lg transition">
          <i class="fas fa-sign-out-alt mr-3"></i>Logout
        </a>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-auto">
      <!-- Top Bar -->
      <header class="bg-white shadow-sm p-6 border-b border-gray-100">
        <div class="flex justify-between items-center">
          <div>
            <h2 class="text-2xl font-bold text-gray-800">Kelola Pemesanan & Pembayaran</h2>
            <p class="text-sm text-gray-500 mt-1">Verifikasi bukti pembayaran dari pendaki</p>
          </div>
          <div class="flex items-center space-x-4">
            <div class="text-right">
              <p class="text-sm text-gray-500">Admin</p>
              <p class="font-semibold text-gray-800">Administrator</p>
            </div>
            <div class="w-10 h-10 bg-gradient-to-r from-purple-600 to-pink-600 rounded-full flex items-center justify-center text-white">
              <i class="fas fa-user"></i>
            </div>
          </div>
        </div>
      </header>

      <!-- Flash Messages -->
      <% if (locals.success && success.length > 0) { %>
        <div class="mx-6 mt-6 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg flex items-center">
          <i class="fas fa-check-circle mr-2"></i>
          <span><%= success[0] %></span>
        </div>
      <% } %>
      <% if (locals.error && error.length > 0) { %>
        <div class="mx-6 mt-6 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg flex items-center">
          <i class="fas fa-exclamation-circle mr-2"></i>
          <span><%= error[0] %></span>
        </div>
      <% } %>

      <!-- Content -->
      <div class="p-6">
        <!-- Statistics Cards -->
        <div class="grid grid-cols-1 md:grid-cols-5 gap-6 mb-6">
          <div class="bg-gradient-to-br from-gray-500 to-gray-600 text-white rounded-lg p-6 card-shadow">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-gray-100 text-sm">Total Pemesanan</p>
                <p class="text-3xl font-bold"><%= stats.total %></p>
              </div>
              <i class="fas fa-receipt text-4xl opacity-20"></i>
            </div>
          </div>
          <div class="bg-gradient-to-br from-yellow-500 to-amber-600 text-white rounded-lg p-6 card-shadow">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-yellow-100 text-sm">Menunggu</p>
                <p class="text-3xl font-bold"><%= stats.dibayar %></p>
              </div>
              <i class="fas fa-hourglass-half text-4xl opacity-20"></i>
            </div>
          </div>
          <div class="bg-gradient-to-br from-blue-500 to-indigo-600 text-white rounded-lg p-6 card-shadow">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-blue-100 text-sm">Diverifikasi</p>
                <p class="text-3xl font-bold"><%= stats.diverifikasi %></p>
              </div>
              <i class="fas fa-check-circle text-4xl opacity-20"></i>
            </div>
          </div>
          <div class="bg-gradient-to-br from-red-500 to-rose-600 text-white rounded-lg p-6 card-shadow">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-red-100 text-sm">Ditolak</p>
                <p class="text-3xl font-bold"><%= stats.ditolak %></p>
              </div>
              <i class="fas fa-times-circle text-4xl opacity-20"></i>
            </div>
          </div>
          <div class="bg-gradient-to-br from-green-500 to-emerald-600 text-white rounded-lg p-6 card-shadow">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-green-100 text-sm">Total Pendapatan</p>
                <p class="text-2xl font-bold"><%= formatRupiah(stats.totalPendapatan) %></p>
              </div>
              <i class="fas fa-wallet text-4xl opacity-20"></i>
            </div>
          </div>
        </div>

        <!-- Filter Tabs -->
        <div class="bg-white rounded-lg card-shadow mb-6">
          <div class="flex border-b border-gray-200">
            <button onclick="filterTable('all')" class="filter-tab active px-6 py-4 font-semibold text-gray-700 hover:text-purple-600 transition border-b-2 border-transparent hover:border-purple-600" data-filter="all">
              <i class="fas fa-list mr-2"></i>Semua
            </button>
            <button onclick="filterTable('dibayar')" class="filter-tab px-6 py-4 font-semibold text-gray-500 hover:text-purple-600 transition border-b-2 border-transparent hover:border-purple-600" data-filter="dibayar">
              <i class="fas fa-hourglass-half mr-2"></i>Menunggu Verifikasi (<%= stats.dibayar %>)
            </button>
            <button onclick="filterTable('pending')" class="filter-tab px-6 py-4 font-semibold text-gray-500 hover:text-purple-600 transition border-b-2 border-transparent hover:border-purple-600" data-filter="pending">
              <i class="fas fa-clock mr-2"></i>Pending (<%= stats.pending %>)
            </button>
            <button onclick="filterTable('diverifikasi')" class="filter-tab px-6 py-4 font-semibold text-gray-500 hover:text-purple-600 transition border-b-2 border-transparent hover:border-purple-600" data-filter="diverifikasi">
              <i class="fas fa-check-circle mr-2"></i>Diverifikasi (<%= stats.diverifikasi %>)
            </button>
            <button onclick="filterTable('ditolak')" class="filter-tab px-6 py-4 font-semibold text-gray-500 hover:text-purple-600 transition border-b-2 border-transparent hover:border-purple-600" data-filter="ditolak">
              <i class="fas fa-times-circle mr-2"></i>Ditolak (<%= stats.ditolak %>)
            </button>
          </div>

          <!-- Pemesanan Table -->
          <div class="overflow-x-auto p-6">
            <% if (pemesanan && pemesanan.length > 0) { %>
              <table class="table-custom w-full" id="pemesananTable">
                <thead>
                  <tr>
                    <th>Kode Booking</th>
                    <th>Nama Pendaki</th>
                    <th>Gunung</th>
                    <th>Tanggal</th>
                    <th>Anggota</th>
                    <th>Total Bayar</th>
                    <th>Status</th>
                    <th>Aksi</th>
                  </tr>
                </thead>
                <tbody>
                  <% pemesanan.forEach(p => { %>
                    <tr class="pemesanan-row" data-status="<%= p.status %>">
                      <td>
                        <span class="font-mono text-xs font-bold text-purple-600"><%= p.kode_booking %></span>
                      </td>
                      <td class="font-semibold text-gray-800">
                        <div><%= p.nama_user %></div>
                        <div class="text-xs text-gray-500"><%= p.email_user %></div>
                      </td>
                      <td class="text-gray-600">
                        <div><%= p.nama_gunung %></div>
                        <div class="text-xs text-gray-500"><%= p.ketinggian %> mdpl</div>
                      </td>
                      <td class="text-gray-600 text-sm">
                        <div><%= new Date(p.tanggal_masuk).toLocaleDateString('id-ID', { day: 'numeric', month: 'short' }) %></div>
                        <div>- <%= new Date(p.tanggal_keluar).toLocaleDateString('id-ID', { day: 'numeric', month: 'short' }) %></div>
                      </td>
                      <td class="text-center text-gray-600"><%= p.jumlah_anggota %></td>
                      <td class="font-bold text-green-600"><%= formatRupiah(p.total_bayar) %></td>
                      <td>
                        <% if (p.status === 'pending') { %>
                          <span class="badge bg-gray-100 text-gray-800">
                            <i class="fas fa-clock mr-1"></i>Pending
                          </span>
                        <% } else if (p.status === 'dibayar') { %>
                          <span class="badge bg-yellow-100 text-yellow-800">
                            <i class="fas fa-hourglass-half mr-1"></i>Menunggu Verifikasi
                          </span>
                        <% } else if (p.status === 'diverifikasi') { %>
                          <span class="badge bg-green-100 text-green-800">
                            <i class="fas fa-check-circle mr-1"></i>Diverifikasi
                          </span>
                        <% } else if (p.status === 'ditolak') { %>
                          <span class="badge bg-red-100 text-red-800">
                            <i class="fas fa-times-circle mr-1"></i>Ditolak
                          </span>
                        <% } %>
                      </td>
                      <td>
                        <a href="/admin/pemesanan/<%= p.id %>" class="text-purple-600 hover:text-purple-800 transition font-semibold text-sm">
                          <i class="fas fa-eye mr-1"></i>Detail
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            <% } else { %>
              <div class="text-center py-12">
                <i class="fas fa-inbox text-6xl text-gray-300 mb-4"></i>
                <h3 class="text-xl font-bold text-gray-600 mb-2">Belum ada pemesanan</h3>
                <p class="text-gray-500">Data pemesanan akan muncul setelah ada pendaki yang mendaftar.</p>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </main>
  </div>

  <!-- Filter Script -->
  <script>
    function filterTable(status) {
      const rows = document.querySelectorAll('.pemesanan-row');
      const tabs = document.querySelectorAll('.filter-tab');

      // Update active tab
      tabs.forEach(tab => {
        if (tab.dataset.filter === status) {
          tab.classList.add('text-purple-600', 'border-purple-600');
          tab.classList.remove('text-gray-500', 'border-transparent');
        } else {
          tab.classList.remove('text-purple-600', 'border-purple-600');
          tab.classList.add('text-gray-500', 'border-transparent');
        }
      });

      // Filter rows
      rows.forEach(row => {
        if (status === 'all' || row.dataset.status === status) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    }
  </script>
</body>
</html>
