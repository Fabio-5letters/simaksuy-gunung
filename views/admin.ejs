<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - SIMAKSI</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    * {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    .sidebar {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    .sidebar-item:hover {
      background: rgba(255, 255, 255, 0.2);
    }
    .card-shadow {
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
      transition: all 0.3s ease;
    }
    .card-shadow:hover {
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
      transform: translateY(-2px);
    }
    .stat-card {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }
    .tab-active {
      border-bottom: 3px solid #667eea;
      color: #667eea;
    }
    .input-custom {
      border: 1px solid #e5e7eb;
      border-radius: 0.5rem;
      padding: 0.75rem;
      transition: all 0.3s ease;
    }
    .input-custom:focus {
      outline: none;
      border-color: #667eea;
      box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }
    .table-custom {
      border-collapse: collapse;
    }
    .table-custom th {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 1rem;
      text-align: left;
    }
    .table-custom td {
      padding: 1rem;
      border-bottom: 1px solid #e5e7eb;
    }
    .table-custom tbody tr:hover {
      background: #f9fafb;
    }
  </style>
</head>
<body class="bg-gray-100">
  <div class="flex h-screen">
    <!-- Sidebar -->
    <aside class="sidebar w-64 text-white p-6 overflow-y-auto">
      <div class="mb-8">
        <div class="flex items-center space-x-3 mb-1">
          <i class="fas fa-mountain text-2xl"></i>
          <h1 class="text-2xl font-bold">SIMAKSI</h1>
        </div>
        <p class="text-purple-200 text-sm">Admin Panel</p>
      </div>
      
      <nav class="space-y-2">
        <a href="/admin" class="sidebar-item block px-4 py-3 rounded-lg transition bg-white bg-opacity-20 shadow-lg"><i class="fas fa-chart-line mr-3"></i>Dashboard</a>
        <a href="/admin/gunung" class="sidebar-item block px-4 py-3 rounded-lg transition hover:bg-white hover:bg-opacity-10"><i class="fas fa-mountain mr-3"></i>Kelola Gunung</a>
        <a href="/admin/berita" class="sidebar-item block px-4 py-3 rounded-lg transition hover:bg-white hover:bg-opacity-10"><i class="fas fa-newspaper mr-3"></i>Kelola Berita</a>
        <a href="/admin/pendakian" class="sidebar-item block px-4 py-3 rounded-lg transition hover:bg-white hover:bg-opacity-10"><i class="fas fa-person-hiking mr-3"></i>Kelola Pendakian</a>
        <a href="/admin/pemesanan" class="sidebar-item block px-4 py-3 rounded-lg transition hover:bg-white hover:bg-opacity-10"><i class="fas fa-shopping-cart mr-3"></i>Data Pemesanan</a>
        <hr class="my-4 border-purple-400">
        <a href="/logout" class="sidebar-item block px-4 py-3 rounded-lg transition hover:bg-white hover:bg-opacity-10"><i class="fas fa-sign-out-alt mr-3"></i>Logout</a>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-auto">
      <!-- Top Bar -->
      <header class="bg-white shadow-sm p-6 border-b border-gray-100">
        <div class="flex justify-between items-center">
          <h2 class="text-2xl font-bold text-gray-800">Dashboard Admin</h2>
          <div class="flex items-center space-x-4">
            <div class="text-right">
              <p class="text-sm text-gray-500">Admin</p>
              <p class="font-semibold text-gray-800">Administrator</p>
            </div>
            <div class="w-10 h-10 bg-gradient-to-r from-purple-600 to-pink-600 rounded-full flex items-center justify-center text-white">
              <i class="fas fa-user"></i>
            </div>
          </div>
        </div>
      </header>

      <!-- Content -->
      <div class="p-6">
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-6">
          <div class="stat-card text-white rounded-lg p-6 card-shadow">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-purple-100 text-sm">Total Gunung</p>
                <p class="text-4xl font-bold"><%= gunung.length %></p>
              </div>
              <i class="fas fa-mountain text-5xl opacity-20"></i>
            </div>
          </div>
          <div class="bg-gradient-to-br from-green-500 to-teal-600 text-white rounded-lg p-6 card-shadow">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-green-100 text-sm">Total Berita</p>
                <p class="text-4xl font-bold"><%= berita.length %></p>
              </div>
              <i class="fas fa-newspaper text-5xl opacity-20"></i>
            </div>
          </div>
          <div class="bg-gradient-to-br from-orange-500 to-red-600 text-white rounded-lg p-6 card-shadow">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-orange-100 text-sm">Pendakian Pending</p>
                <p class="text-4xl font-bold"><%= simaksi.filter(s => s.status_pengajuan === 'Pending').length %></p>
              </div>
              <i class="fas fa-hourglass-start text-5xl opacity-20"></i>
            </div>
          </div>
          <div class="bg-gradient-to-br from-blue-500 to-indigo-600 text-white rounded-lg p-6 card-shadow">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-blue-100 text-sm">Total Pendakian</p>
                <p class="text-4xl font-bold"><%= simaksi.length %></p>
              </div>
              <i class="fas fa-person-hiking text-5xl opacity-20"></i>
            </div>
          </div>
        </div>

        <!-- Pemesanan Stats -->
        <div class="bg-white rounded-lg card-shadow p-6 mb-6">
          <div class="flex justify-between items-center mb-4">
            <h3 class="text-xl font-bold text-gray-800 flex items-center">
              <i class="fas fa-money-check-alt mr-3 text-purple-600"></i>Statistik Pemesanan & Pembayaran
            </h3>
            <a href="/admin/pemesanan" class="bg-gradient-to-r from-purple-600 to-pink-600 text-white font-bold py-2 px-6 rounded-lg hover:shadow-lg transition">
              <i class="fas fa-external-link-alt mr-2"></i>Kelola Pemesanan
            </a>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-gray-50 rounded-lg p-4 text-center border-l-4 border-gray-400">
              <p class="text-sm text-gray-500">Total Pemesanan</p>
              <p class="text-2xl font-bold text-gray-700"><%= pemesananStats.total %></p>
            </div>
            <div class="bg-yellow-50 rounded-lg p-4 text-center border-l-4 border-yellow-400">
              <p class="text-sm text-yellow-600">Menunggu Verifikasi</p>
              <p class="text-2xl font-bold text-yellow-700"><%= pemesananStats.dibayar %></p>
            </div>
            <div class="bg-green-50 rounded-lg p-4 text-center border-l-4 border-green-400">
              <p class="text-sm text-green-600">Diverifikasi</p>
              <p class="text-2xl font-bold text-green-700"><%= pemesananStats.diverifikasi %></p>
            </div>
            <div class="bg-red-50 rounded-lg p-4 text-center border-l-4 border-red-400">
              <p class="text-sm text-red-600">Ditolak</p>
              <p class="text-2xl font-bold text-red-700"><%= pemesananStats.ditolak %></p>
            </div>
          </div>
          <p class="text-xs text-gray-500 mt-3">
            <i class="fas fa-info-circle mr-1"></i>Klik "Kelola Pemesanan" untuk melihat detail dan memverifikasi pembayaran
          </p>
        </div>

        <!-- Tabs Navigation -->
        <div class="bg-white rounded-lg card-shadow mb-6">
          <div class="flex border-b border-gray-200">
            <button class="tab-active px-6 py-4 font-semibold transition"><i class="fas fa-mountain mr-2"></i>Kelola Gunung</button>
            <button class="px-6 py-4 font-semibold text-gray-500 hover:text-gray-700 transition"><i class="fas fa-newspaper mr-2"></i>Kelola Berita</button>
            <button class="px-6 py-4 font-semibold text-gray-500 hover:text-gray-700 transition"><i class="fas fa-person-hiking mr-2"></i>Kelola Pendakian</button>
          </div>

          <!-- Tab Content -->
          <div class="p-6">
            <!-- Kelola Gunung Section -->
            <section id="gunung-section">
              <h3 class="text-xl font-bold text-gray-800 mb-6 flex items-center"><i class="fas fa-plus-circle mr-3 text-purple-600"></i>Tambah Gunung Baru</h3>
              
              <form action="/admin/gunung" method="POST" class="bg-gray-50 rounded-lg p-6 mb-8 border border-gray-200">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Nama Gunung</label>
                    <input type="text" name="nama_gunung" placeholder="Contoh: Gunung Merbabu" class="input-custom w-full" required>
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Lokasi</label>
                    <input type="text" name="lokasi" placeholder="Contoh: Semarang, Jawa Tengah" class="input-custom w-full" required>
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Ketinggian (mdpl)</label>
                    <input type="number" name="ketinggian" placeholder="3142" class="input-custom w-full" required>
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Kuota Harian</label>
                    <input type="number" name="kuota_harian" placeholder="100" class="input-custom w-full" required>
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Status</label>
                    <select name="status" class="input-custom w-full" required>
                      <option value="Buka">Buka</option>
                      <option value="Tutup">Tutup</option>
                    </select>
                  </div>
                </div>
                <button type="submit" class="bg-gradient-to-r from-purple-600 to-pink-600 text-white font-bold py-2 px-6 rounded-lg hover:shadow-lg transition">
                  <i class="fas fa-save mr-2"></i>Tambah Gunung
                </button>
              </form>

              <h3 class="text-xl font-bold text-gray-800 mb-4 flex items-center"><i class="fas fa-list mr-3 text-purple-600"></i>Daftar Gunung</h3>
              <div class="overflow-x-auto">
                <table class="table-custom w-full">
                  <thead>
                    <tr>
                      <th>Nama Gunung</th>
                      <th>Lokasi</th>
                      <th>Ketinggian (mdpl)</th>
                      <th>Kuota Harian</th>
                      <th>Status</th>
                      <th>Aksi</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% gunung.forEach(g => { %>
                      <tr>
                        <td class="font-semibold text-gray-800"><%= g.nama_gunung %></td>
                        <td class="text-gray-600"><%= g.lokasi %></td>
                        <td class="text-gray-600"><%= g.ketinggian %> m</td>
                        <td class="text-gray-600"><%= g.kuota_harian %> orang</td>
                        <td>
                          <span class="<%= g.status === 'Buka' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %> px-3 py-1 rounded-full text-sm font-semibold">
                            <i class="fas <%= g.status === 'Buka' ? 'fa-check-circle' : 'fa-times-circle' %> mr-1"></i><%= g.status %>
                          </span>
                        </td>
                        <td>
                          <button class="text-purple-600 hover:text-purple-800 transition font-semibold">
                            <i class="fas fa-edit mr-1"></i>Edit
                          </button>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </section>
          </div>
        </div>

        <!-- Kelola Berita Section -->
        <div class="bg-white rounded-lg card-shadow p-6 mb-6">
          <h3 class="text-xl font-bold text-gray-800 mb-6 flex items-center"><i class="fas fa-plus-circle mr-3 text-green-600"></i>Tambah Berita Baru</h3>
          
          <form action="/admin/berita" method="POST" class="bg-gray-50 rounded-lg p-6 mb-8 border border-gray-200">
            <div class="mb-4">
              <label class="block text-sm font-semibold text-gray-700 mb-2">Judul Berita</label>
              <input type="text" name="judul" placeholder="Masukkan judul berita" class="input-custom w-full" required>
            </div>
            <div class="mb-4">
              <label class="block text-sm font-semibold text-gray-700 mb-2">Isi Berita</label>
              <textarea name="isi_berita" placeholder="Masukkan isi berita" class="input-custom w-full h-32" required></textarea>
            </div>
            <div class="mb-4">
              <label class="block text-sm font-semibold text-gray-700 mb-2">Tanggal Publikasi</label>
              <input type="date" name="tanggal" class="input-custom w-full" required>
            </div>
            <button type="submit" class="bg-gradient-to-r from-green-600 to-teal-600 text-white font-bold py-2 px-6 rounded-lg hover:shadow-lg transition">
              <i class="fas fa-save mr-2"></i>Publikasikan Berita
            </button>
          </form>

          <h3 class="text-xl font-bold text-gray-800 mb-4 flex items-center"><i class="fas fa-list mr-3 text-green-600"></i>Daftar Berita</h3>
          <div class="space-y-4">
            <% berita.forEach(b => { %>
              <div class="bg-gradient-to-r from-gray-50 to-gray-100 rounded-lg p-4 border-l-4 border-green-600 card-shadow">
                <div class="flex justify-between items-start">
                  <div>
                    <h4 class="text-lg font-bold text-gray-800"><%= b.judul %></h4>
                    <p class="text-gray-600 mt-2"><%= b.isi_berita.substring(0, 100) %>...</p>
                    <div class="flex items-center space-x-4 mt-3 text-sm text-gray-500">
                      <span><i class="fas fa-calendar mr-1"></i><%= b.tanggal %></span>
                    </div>
                  </div>
                  <button class="text-red-600 hover:text-red-800 transition font-semibold">
                    <i class="fas fa-trash-alt"></i>
                  </button>
                </div>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Kelola Simaksi Section -->
        <div class="bg-white rounded-lg card-shadow p-6">
          <h3 class="text-xl font-bold text-gray-800 mb-6 flex items-center"><i class="fas fa-list mr-3 text-blue-600"></i>Kelola Pendakian</h3>
          
          <div class="overflow-x-auto">
            <table class="table-custom w-full">
              <thead>
                <tr>
                  <th>Nama Pendaki</th>
                  <th>Gunung</th>
                  <th>Tanggal Pendakian</th>
                  <th>Jumlah Anggota</th>
                  <th>Status</th>
                  <th>Aksi</th>
                </tr>
              </thead>
              <tbody>
                <% simaksi.forEach(s => { %>
                  <tr>
                    <td class="font-semibold text-gray-800"><%= s.nama %></td>
                    <td class="text-gray-600"><%= s.nama_gunung %></td>
                    <td class="text-gray-600"><%= s.tanggal_pendakian %></td>
                    <td class="text-gray-600"><%= s.jumlah_anggota %> orang</td>
                    <td>
                      <span class="<%= s.status_pengajuan === 'Disetujui' ? 'bg-green-100 text-green-800' : s.status_pengajuan === 'Ditolak' ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800' %> px-3 py-1 rounded-full text-sm font-semibold">
                        <i class="fas <%= s.status_pengajuan === 'Disetujui' ? 'fa-check-circle' : s.status_pengajuan === 'Ditolak' ? 'fa-times-circle' : 'fa-hourglass-start' %> mr-1"></i><%= s.status_pengajuan %>
                      </span>
                    </td>
                    <td>
                      <form action="/admin/simaksi/<%= s.id %>" method="POST" class="flex gap-2">
                        <select name="status_pengajuan" class="input-custom text-sm">
                          <option value="Pending" <%= s.status_pengajuan === 'Pending' ? 'selected' : '' %>>Pending</option>
                          <option value="Disetujui" <%= s.status_pengajuan === 'Disetujui' ? 'selected' : '' %>>Disetujui</option>
                          <option value="Ditolak" <%= s.status_pengajuan === 'Ditolak' ? 'selected' : '' %>>Ditolak</option>
                        </select>
                        <button type="submit" class="bg-blue-600 text-white font-bold py-1 px-3 rounded hover:bg-blue-700 transition text-sm">
                          Update
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>
</html>