<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - SIMAKSI</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');
    * { font-family: 'Plus Jakarta Sans', sans-serif; }
    .sidebar { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .card-shadow { box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1); }
  </style>
</head>
<body class="bg-gray-50">
  <div class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="sidebar w-64 text-white p-6 overflow-y-auto shrink-0">
      <div class="mb-10">
        <div class="flex items-center space-x-3 mb-1">
          <i class="fas fa-mountain-sun text-3xl"></i>
          <h1 class="text-2xl font-bold tracking-tight">SIMAKSI</h1>
        </div>
        <p class="text-purple-200 text-xs uppercase tracking-widest font-semibold">Admin Dashboard</p>
      </div>
      
      <nav class="space-y-2">
        <a href="/admin" class="flex items-center px-4 py-3 rounded-xl bg-white bg-opacity-20 shadow-lg transition">
          <i class="fas fa-chart-pie mr-3"></i>Dashboard
        </a>
        <a href="/admin/pemesanan" class="flex items-center px-4 py-3 rounded-xl hover:bg-white hover:bg-opacity-10 transition">
          <i class="fas fa-shopping-cart mr-3"></i>Data Pemesanan
        </a>
        <div class="pt-4 pb-2">
          <p class="px-4 text-[10px] font-bold text-purple-200 uppercase tracking-widest">Manajemen</p>
        </div>
        <a href="/admin/gunung" class="flex items-center px-4 py-3 rounded-xl hover:bg-white hover:bg-opacity-10 transition">
          <i class="fas fa-mountain mr-3"></i>Kelola Gunung
        </a>
        <a href="/admin/berita" class="flex items-center px-4 py-3 rounded-xl hover:bg-white hover:bg-opacity-10 transition">
          <i class="fas fa-newspaper mr-3"></i>Kelola Berita
        </a>
        <a href="/admin/pendakian" class="flex items-center px-4 py-3 rounded-xl hover:bg-white hover:bg-opacity-10 transition">
          <i class="fas fa-calendar-alt mr-3"></i>Kelola Pendakian
        </a>
        <hr class="my-6 border-purple-400 opacity-30">
        <a href="/logout" class="flex items-center px-4 py-3 rounded-xl hover:bg-red-500 transition text-red-100">
          <i class="fas fa-sign-out-alt mr-3"></i>Keluar
        </a>
      </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-y-auto">
      <!-- Top Bar -->
      <header class="bg-white border-b border-gray-100 p-6 sticky top-0 z-10">
        <div class="flex justify-between items-center">
          <h2 class="text-2xl font-extrabold text-gray-800 tracking-tight">Ringkasan Statistik</h2>
          <div class="flex items-center space-x-4">
            <div class="text-right">
              <p class="text-xs font-bold text-purple-600 uppercase tracking-tighter">Administrator</p>
              <p class="text-sm font-semibold text-gray-700">Selamat Datang!</p>
            </div>
            <img src="https://ui-avatars.com/api/?name=Admin&background=667eea&color=fff" class="w-10 h-10 rounded-xl border-2 border-white shadow-sm">
          </div>
        </div>
      </header>

      <div class="p-8">
        <!-- Quick Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
          <div class="bg-white p-6 rounded-2xl card-shadow border-l-4 border-blue-500">
            <p class="text-gray-400 text-xs font-bold uppercase mb-1">Total Gunung</p>
            <p class="text-3xl font-black text-gray-800"><%= gunung.length %></p>
          </div>
          <div class="bg-white p-6 rounded-2xl card-shadow border-l-4 border-green-500">
            <p class="text-gray-400 text-xs font-bold uppercase mb-1">Berita Aktif</p>
            <p class="text-3xl font-black text-gray-800"><%= berita.length %></p>
          </div>
          <div class="bg-white p-6 rounded-2xl card-shadow border-l-4 border-orange-500">
            <p class="text-gray-400 text-xs font-bold uppercase mb-1">Total SIMAKSI</p>
            <p class="text-3xl font-black text-gray-800"><%= simaksi.length %></p>
          </div>
          <div class="bg-white p-6 rounded-2xl card-shadow border-l-4 border-purple-500">
            <p class="text-gray-400 text-xs font-bold uppercase mb-1">Pendaki Terdaftar</p>
            <p class="text-3xl font-black text-gray-800"><%= pemesananStats.total %></p>
          </div>
        </div>

        <!-- Pemesanan & Pembayaran Stats (MAIN SECTION) -->
        <div class="bg-white rounded-3xl card-shadow overflow-hidden mb-8">
          <div class="bg-gradient-to-r from-purple-600 to-indigo-600 p-8 text-white">
            <div class="flex justify-between items-center">
              <div>
                <h3 class="text-2xl font-bold mb-2 flex items-center">
                  <i class="fas fa-wallet mr-3"></i>Statistik Pembayaran & Pemesanan
                </h3>
                <p class="text-purple-100 opacity-80">Pantau arus transaksi dan verifikasi pembayaran secara real-time</p>
              </div>
              <a href="/admin/pemesanan" class="bg-white text-purple-600 font-bold py-3 px-8 rounded-2xl hover:shadow-xl transition flex items-center">
                <i class="fas fa-list-check mr-2"></i>Kelola Data
              </a>
            </div>
          </div>
          
          <div class="p-8 grid grid-cols-1 md:grid-cols-4 gap-6">
            <div class="bg-gray-50 p-6 rounded-2xl border border-gray-100">
              <div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center mb-4 text-xl">
                <i class="fas fa-receipt"></i>
              </div>
              <p class="text-gray-500 text-sm font-medium">Total Pemesanan</p>
              <p class="text-3xl font-black text-gray-800"><%= pemesananStats.total %></p>
            </div>
            
            <div class="bg-yellow-50 p-6 rounded-2xl border border-yellow-100">
              <div class="w-12 h-12 bg-yellow-100 text-yellow-600 rounded-xl flex items-center justify-center mb-4 text-xl">
                <i class="fas fa-clock"></i>
              </div>
              <p class="text-yellow-600 text-sm font-medium">Menunggu Verifikasi</p>
              <p class="text-3xl font-black text-yellow-700"><%= pemesananStats.dibayar %></p>
            </div>
            
            <div class="bg-green-50 p-6 rounded-2xl border border-green-100">
              <div class="w-12 h-12 bg-green-100 text-green-600 rounded-xl flex items-center justify-center mb-4 text-xl">
                <i class="fas fa-check-double"></i>
              </div>
              <p class="text-green-600 text-sm font-medium">Berhasil Diverifikasi</p>
              <p class="text-3xl font-black text-green-700"><%= pemesananStats.diverifikasi %></p>
            </div>
            
            <div class="bg-red-50 p-6 rounded-2xl border border-red-100">
              <div class="w-12 h-12 bg-red-100 text-red-600 rounded-xl flex items-center justify-center mb-4 text-xl">
                <i class="fas fa-ban"></i>
              </div>
              <p class="text-red-600 text-sm font-medium">Pemesanan Ditolak</p>
              <p class="text-3xl font-black text-red-700"><%= pemesananStats.ditolak %></p>
            </div>
          </div>

          <!-- Progress Bar Summary -->
          <div class="px-8 pb-8">
            <div class="bg-gray-100 h-4 rounded-full overflow-hidden flex">
              <% 
                const total = pemesananStats.total || 1;
                const pVerif = (pemesananStats.diverifikasi / total) * 100;
                const pWait = (pemesananStats.dibayar / total) * 100;
                const pRej = (pemesananStats.ditolak / total) * 100;
                const pPend = (pemesananStats.pending / total) * 100;
              %>
              <div class="bg-green-500 h-full" style="width: <%= pVerif %>%" title="Diverifikasi"></div>
              <div class="bg-yellow-400 h-full" style="width: <%= pWait %>%" title="Menunggu"></div>
              <div class="bg-red-500 h-full" style="width: <%= pRej %>%" title="Ditolak"></div>
              <div class="bg-gray-300 h-full" style="width: <%= pPend %>%" title="Pending"></div>
            </div>
            <div class="flex justify-between mt-3 text-[10px] font-bold text-gray-400 uppercase tracking-widest">
              <span>Efisiensi Verifikasi: <%= Math.round(pVerif) %>%</span>
              <span>Total Transaksi Berjalan</span>
            </div>
          </div>
        </div>

        <!-- Shortcuts -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <a href="/admin/gunung" class="bg-white p-6 rounded-2xl card-shadow hover:scale-[1.02] transition border border-gray-100 group">
            <div class="flex justify-between items-center">
              <div class="flex items-center">
                <div class="w-10 h-10 bg-purple-100 text-purple-600 rounded-lg flex items-center justify-center mr-4 group-hover:bg-purple-600 group-hover:text-white transition">
                  <i class="fas fa-mountain"></i>
                </div>
                <span class="font-bold text-gray-700">Update Data Gunung</span>
              </div>
              <i class="fas fa-chevron-right text-gray-300"></i>
            </div>
          </a>
          <a href="/admin/berita" class="bg-white p-6 rounded-2xl card-shadow hover:scale-[1.02] transition border border-gray-100 group">
            <div class="flex justify-between items-center">
              <div class="flex items-center">
                <div class="w-10 h-10 bg-green-100 text-green-600 rounded-lg flex items-center justify-center mr-4 group-hover:bg-green-600 group-hover:text-white transition">
                  <i class="fas fa-newspaper"></i>
                </div>
                <span class="font-bold text-gray-700">Tulis Berita Baru</span>
              </div>
              <i class="fas fa-chevron-right text-gray-300"></i>
            </div>
          </a>
          <a href="/admin/pendakian" class="bg-white p-6 rounded-2xl card-shadow hover:scale-[1.02] transition border border-gray-100 group">
            <div class="flex justify-between items-center">
              <div class="flex items-center">
                <div class="w-10 h-10 bg-orange-100 text-orange-600 rounded-lg flex items-center justify-center mr-4 group-hover:bg-orange-600 group-hover:text-white transition">
                  <i class="fas fa-calendar-alt"></i>
                </div>
                <span class="font-bold text-gray-700">Jadwal Pendakian</span>
              </div>
              <i class="fas fa-chevron-right text-gray-300"></i>
            </div>
          </a>
        </div>
      </div>
    </main>
  </div>
</body>
</html>