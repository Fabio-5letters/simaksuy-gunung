<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kelola Pendakian - SIMAKSI Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');
    * { font-family: 'Plus Jakarta Sans', sans-serif; }
    .sidebar { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .sidebar-item:hover { background: rgba(255, 255, 255, 0.2); }
    .sidebar-item.active { background: rgba(255, 255, 255, 0.2); border-left: 4px solid white; }
  </style>
</head>
<body class="bg-gray-100 min-h-screen">
  <div class="flex">
    <!-- Sidebar -->
    <aside class="sidebar w-64 min-h-screen text-white p-6 sticky top-0 h-screen overflow-y-auto">
        <div class="mb-10">
            <div class="flex items-center space-x-3 mb-1">
                <i class="fas fa-mountain-sun text-3xl"></i>
                <h1 class="text-2xl font-bold tracking-tight">SIMAKSI</h1>
            </div>
            <p class="text-purple-200 text-xs uppercase tracking-widest font-semibold">Admin Panel</p>
        </div>

        <nav class="space-y-2">
            <a href="/admin" class="sidebar-item block px-4 py-3 rounded-xl transition">
                <i class="fas fa-chart-pie mr-3"></i>Dashboard
            </a>
            <a href="/admin/pemesanan" class="sidebar-item block px-4 py-3 rounded-xl transition">
                <i class="fas fa-shopping-cart mr-3"></i>Data Pemesanan
            </a>
            <div class="pt-4 pb-2">
                <p class="px-4 text-[10px] font-bold text-purple-200 uppercase tracking-widest">Manajemen</p>
            </div>
            <a href="/admin/gunung" class="sidebar-item block px-4 py-3 rounded-xl transition">
                <i class="fas fa-mountain mr-3"></i>Kelola Gunung
            </a>
            <a href="/admin/berita" class="sidebar-item block px-4 py-3 rounded-xl transition">
                <i class="fas fa-newspaper mr-3"></i>Kelola Berita
            </a>
            <a href="/admin/pendakian" class="sidebar-item active block px-4 py-3 rounded-xl transition">
                <i class="fas fa-calendar-alt mr-3"></i>Kelola Pendakian
            </a>
            <hr class="my-6 border-purple-400 opacity-30">
            <a href="/logout" class="sidebar-item block px-4 py-3 rounded-xl hover:bg-red-500 transition text-red-100">
                <i class="fas fa-sign-out-alt mr-3"></i>Keluar
            </a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-8">
      <div class="flex justify-between items-center mb-8">
        <div>
          <h2 class="text-3xl font-bold text-gray-800 tracking-tight">Kelola Pendakian</h2>
          <p class="text-gray-500 font-medium">Manajemen jadwal dan status pendakian massal</p>
        </div>
        <div class="flex items-center space-x-4 bg-white p-2 rounded-2xl shadow-sm border border-gray-100">
          <div class="text-right px-3">
              <p class="text-[10px] font-bold text-purple-600 uppercase">Administrator</p>
              <p class="text-sm font-semibold text-gray-700">Admin</p>
          </div>
          <img src="https://ui-avatars.com/api/?name=Admin&background=667eea&color=fff" class="w-10 h-10 rounded-xl">
        </div>
      </div>

      <!-- Add Pendakian Form -->
      <div class="bg-white rounded-3xl shadow-xl p-8 mb-8 border border-gray-100">
        <h3 class="text-xl font-bold mb-6 flex items-center text-gray-800">
          <i class="fas fa-plus-circle mr-3 text-purple-600"></i> Tambah Jadwal Pendakian
        </h3>
        <form action="/admin/pendakian" method="POST">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div>
              <label for="nama_pendakian" class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">Nama Acara</label>
              <input type="text" name="nama_pendakian" id="nama_pendakian" required placeholder="Contoh: Pendakian Massal Merapi" 
                class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl p-4 font-bold text-gray-700 focus:border-purple-500 focus:outline-none transition">
            </div>
            <div>
              <label for="tanggal" class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">Tanggal Pelaksanaan</label>
              <input type="date" name="tanggal" id="tanggal" required 
                class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl p-4 font-bold text-gray-700 focus:border-purple-500 focus:outline-none transition">
            </div>
            <div>
              <label for="status" class="block text-[10px] font-black text-gray-400 uppercase tracking-widest mb-2">Status Pendaftaran</label>
              <select name="status" id="status" required class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl p-4 font-bold text-gray-700 focus:border-purple-500 focus:outline-none transition appearance-none cursor-pointer">
                <option value="Buka">Buka</option>
                <option value="Tutup">Tutup</option>
                <option value="Penuh">Penuh</option>
              </select>
            </div>
          </div>
          <div class="mt-8 flex justify-end">
            <button type="submit" class="bg-purple-600 hover:bg-purple-700 text-white font-black py-4 px-10 rounded-2xl shadow-xl shadow-purple-100 transition transform hover:-translate-y-1 active:translate-y-0">
              <i class="fas fa-save mr-2"></i> SIMPAN JADWAL
            </button>
          </div>
        </form>
      </div>

      <!-- Pendakian List -->
      <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100">
        <div class="p-8 border-b border-gray-50 flex justify-between items-center bg-gray-50/50">
          <h3 class="text-xl font-bold text-gray-800 flex items-center">
            <i class="fas fa-calendar-check mr-3 text-purple-600"></i>Daftar Jadwal
          </h3>
          <span class="bg-purple-100 text-purple-700 text-[10px] font-black px-4 py-1.5 rounded-full uppercase tracking-widest"><%= pendakian.length %> PENDAKIAN</span>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="bg-gray-50/50 text-gray-400 uppercase text-[10px] font-black tracking-widest border-b border-gray-100">
                <th class="px-8 py-5">Nama Pendakian</th>
                <th class="px-8 py-5 text-center">Tanggal</th>
                <th class="px-8 py-5 text-center">Status</th>
                <th class="px-8 py-5 text-center">Aksi</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              <% if (pendakian && pendakian.length > 0) { %>
                <% pendakian.forEach(item => { %>
                  <tr class="hover:bg-gray-50 transition group">
                    <td class="px-8 py-5 font-bold text-gray-800"><%= item.nama_pendakian %></td>
                    <td class="px-8 py-5 text-center">
                      <span class="font-bold text-gray-600 bg-gray-100 px-3 py-1 rounded-lg">
                        <%= item.tanggal ? new Date(item.tanggal).toLocaleDateString('id-ID', {day:'numeric', month:'short', year:'numeric'}) : '-' %>
                      </span>
                    </td>
                    <td class="px-8 py-5 text-center">
                      <% if (item.status === 'Buka') { %>
                        <span class="bg-green-100 text-green-700 text-[10px] font-black px-3 py-1.5 rounded-full uppercase">Buka</span>
                      <% } else if (item.status === 'Tutup') { %>
                        <span class="bg-red-100 text-red-700 text-[10px] font-black px-3 py-1.5 rounded-full uppercase">Tutup</span>
                      <% } else { %>
                        <span class="bg-yellow-100 text-yellow-700 text-[10px] font-black px-3 py-1.5 rounded-full uppercase">Penuh</span>
                      <% } %>
                    </td>
                    <td class="px-8 py-5">
                      <div class="flex justify-center">
                        <form action="/admin/pendakian/<%= item.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Hapus jadwal ini?')">
                          <button type="submit" class="w-10 h-10 bg-red-50 text-red-500 rounded-xl flex items-center justify-center hover:bg-red-500 hover:text-white transition">
                            <i class="fas fa-trash-alt"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="4" class="px-8 py-20 text-center">
                    <div class="flex flex-col items-center">
                        <i class="fas fa-person-hiking text-5xl text-gray-200 mb-4"></i>
                        <p class="text-gray-400 font-bold uppercase tracking-widest">Belum ada jadwal pendakian</p>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</body>
</html>